      "amount": "a few pinch"
    },
    {
      "name": "Bhuna masala powder",
      "amount": "2 teaspoons"
    },
    {
      "name": "Cheddar cheese, grated",
      "amount": "1/4 cup"
    },
    {
      "name": "Peanut butter (for added richness - optional but recommended)",
      "amount": "a few tablespoons"
    }
  ],
  "instructions": [
    "Heat oil in a pan over medium heat.",
    "Add onions and garlic; saut\u00e9 until translucent.",
    "Stir in tomato paste, salt, and red pepper flakes. Cook for about 2 minutes.",
    "Mix Bhuna masala powder into the sauce to create a fragrant aroma and flavor.",
    "Pour in buttermilk and stir well.",
    "Garnish with grated cheese and if desired, add a few tablespoons of peanut butter for added richness and creaminess.",
    "Stir until cheese is melted and everything combines nicely.",
    "Serve hot."
  ],
