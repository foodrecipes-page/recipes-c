  "ingredients": [
    {
      "name": "Buttermilk",
      "amount": "1/4 cup"
    },
    {
      "name": "Vegetable oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "Onion, finely chopped",
      "amount": "1"
    },
    {
      "name": "Garlic cloves, minced",
      "amount": "3"
    },
    {
      "name": "Tomato paste",
      "amount": "1 tablespoon"
    },
    {
