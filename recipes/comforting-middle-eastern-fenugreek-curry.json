  "instructions": [
    "Heat the oil in a large pan over medium heat.",
    "Add the onion and cook until softened, about 5 minutes.",
    "Add the garlic and ginger and cook for 1 minute.",
    "Add the curry powder and turmeric and cook for 1 minute, stirring constantly.",
    "Add the fenugreek leaves and cook until wilted, about 3 minutes.",
    "Pour in the coconut milk and bring to a simmer.",
    "Reduce the heat to low and cook, covered, for 15 minutes.",
    "Season with salt and pepper to taste.",
    "Serve hot in a lacquerware bowl."
  ],
