  "instructions": [
    "Steam sliced onion in a kazan until softened.",
    "Add minced garlic and steam for another 2 minutes.",
    "Add kombu seaweed, salt, and black peppercorns. Steam for 10 minutes.",
    "Add kombu dashi broth and bring to a simmer.",
    "Remove kombu seaweed and let cool.",
    "Puree the broth using a blender or food processor.",
    "Heat butter in a pan over low heat.",
    "Add white wine vinegar and honey. Stir until dissolved.",
    "Slowly pour the butter mixture into the pureed broth, whisking constantly.",
    "If desired, add kombu powder or flakes for extra flavor.",
    "Stir in heavy cream and cook on low heat for 2 minutes.",
    "Season with salt to taste.",
    "Serve hot, garnished with chopped parsley."
  ],
