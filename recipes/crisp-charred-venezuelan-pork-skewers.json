      "amount": "1/2 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "yogurt",
      "amount": "1/2 cup",
      "notes": "for serving"
    }
  ],
  "instructions": [
    "Preheat the robata grill to 400 degrees Fahrenheit.",
    "In a large bowl, whisk together olive oil, lime juice, garlic, smoked paprika, cumin, cayenne pepper, salt, and black pepper.",
    "Add the pork cubes to the bowl and toss to coat with the marinade.",
    "Thread the marinated pork cubes onto skewers, leaving a small space between each piece.",
    "Grill the skewers for 10-12 minutes, turning occasionally, until the pork is cooked through and slightly charred.",
    "Serve the skewers hot with a side of yogurt for cooling.",
    "Garnish with fresh cilantro or scallions, if desired.",
    "Let the skewers rest for a few minutes before serving.",
    "Serve immediately and enjoy."
  ],
