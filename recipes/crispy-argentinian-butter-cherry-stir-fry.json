{
  "title": "Crispy Argentinian Butter Cherry Stir-fry",
  "description": "A quick-fix Argentine dish featuring dried cherries in a buttery sauce with a crispy texture, perfect for a light meal.",
  "cuisine": "Argentine",
  "diet": [
    "fodmap-friendly"
  ],
