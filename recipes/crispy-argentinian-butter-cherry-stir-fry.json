      "name": "Dried Cherries",
      "amount": "1 cup"
    },
    {
      "name": "Butter",
      "amount": "6 tablespoons"
    },
    {
      "name": "Onion, finely chopped",
      "amount": "1/4 cup"
    },
    {
      "name": "Garlic, minced",
      "amount": "1 clove"
    },
    {
      "name": "Olive Oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "Salt",
      "amount": "to taste"
    },
    {
      "name": "Sugar",
      "amount": "1 tablespoon"
    },
    {
      "name": "Cayenne Pepper (optional)",
      "amount": "a pinch"
    }
  ],
  "instructions": [
    "Heat olive oil in a non-stick skillet over medium heat.",
    "Add finely chopped onion and minced garlic, sauté until translucent.",
    "Stir in dried cherries, salt, sugar, and optional cayenne pepper. Cook for about 2 minutes.",
    "Fold in melted butter and stir well to coat the cherries evenly with the butter mixture.",
    "Cook for an additional minute or two until the cherries are tender and slightly caramelized.",
    "Serve hot as a side dish or alongside grilled meats."
  ],
