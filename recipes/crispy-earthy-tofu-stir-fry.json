  "title": "Crispy Earthy Tofu Stir-fry",
  "description": "A cozy Vietnamese dish featuring crispy tofu and earthy flavors from Demerara sugar in a slow-cooked, dash-friendly recipe.",
  "cuisine": "Vietnamese",
  "diet": null,
