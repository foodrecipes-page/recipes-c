{
  "title": "Cassaba Vitality Feast",
  "description": "A rich, fluffy, energizing Algerian dish featuring cassava root cooked in steam to make it low-carb-friendly.",
  "cuisine": "Algerian",
  "diet": [
    "low-carb"
  ],
