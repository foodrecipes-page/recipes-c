  "ingredients": [
    {
      "name": "Cassava Root",
      "amount": "1 cup peeled and sliced",
      "notes": "Ensure it's thoroughly washed."
    },
    {
      "name": "Olive Oil",
      "amount": "2 tablespoons",
      "notes": "For frying or sautéing if desired."
    },
    {
      "name": "Onion",
      "amount": "1 medium, finely chopped",
      "notes": ""
    },
    {
      "name": "Garlic Cloves",
      "amount": "3 cloves, minced",
      "notes": ""
    },
    {
      "name": "Zucchini",
      "amount": "2 cups, sliced thin",
      "notes": ""
    },
    {
      "name": "Bell Pepper",
      "amount": "1 medium, finely chopped (any color)",
      "notes": ""
    },
    {
      "name": "Leeks",
      "amount": "4-6 stalks, finely chopped",
      "notes": "For added flavor."
    },
    {
      "name": "Lemon Juice",
      "amount": "1/4 cup",
      "notes": ""
    },
    {
      "name": "Fresh Herbs (Thyme and Rosemary)",
      "amount": "To taste",
      "notes": "Optional for extra flavoring."
    }
  ],
  "instructions": [
    "Preheat your oven to 375°F (190°C).",
    "Heat olive oil in a pan over medium heat. Add onions, garlic, and leeks; sauté until softened.",
    "Add cassava root slices, zucchini, and bell pepper into the same pan with the vegetables. Cook for about 10 minutes or until slightly tender but still firm.",
    "Transfer mixture to a steaming dish lined with aluminum foil. Place in preheated oven and steam cook for about 25-30 minutes or until cassava is soft and fluffy.",
    "Drizzle lemon juice over the top before serving. Optionally, garnish with fresh herbs for extra zest."
  ],
