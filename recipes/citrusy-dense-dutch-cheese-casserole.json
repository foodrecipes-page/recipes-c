      "notes": ""
    },
    {
      "name": "Unsalted Butter",
      "amount": "2 tbsp",
      "notes": "melted"
    },
    {
      "name": "Fresh Cilantro",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "In a large mixing bowl, combine the shredded cheese, boiled chicken, cooked rice, orange juice, lemon juice, and orange zest.",
    "In a separate saucepan, heat the chicken broth over low heat.",
    "Add the melted butter to the chicken broth and stir until combined.",
    "Pour the chicken broth mixture over the cheese mixture and stir until well combined.",
    "Transfer the mixture to a 9x13 inch baking dish and smooth the top.",
    "Bake in a preheated oven at 375°F for 25 minutes, or until the casserole is heated through and the cheese is melted and bubbly.",
    "Remove from the oven and sprinkle with chopped cilantro.",
    "Serve hot and enjoy!"
  ],
