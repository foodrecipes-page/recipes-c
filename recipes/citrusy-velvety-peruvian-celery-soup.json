      "amount": "1/4 cup"
    },
    {
      "name": "vegetable stock",
      "amount": "4 cups"
    },
    {
      "name": "lemon juice",
      "amount": "1/2 cup"
    },
    {
      "name": "orange juice",
      "amount": "1/2 cup"
    },
    {
      "name": "ginger",
      "amount": "1-inch piece (grated)"
    },
    {
      "name": "cilantro leaves",
      "amount": "for garnish"
    }
  ],
  "instructions": [
    "Preheat oven to 400°F (205°C).",
    "Cut celery into chunks and toss with butter. Roast until tender, about 10 minutes.",
    "In a large pot, sauté onions and carrots in olive oil until soft, about 5 minutes.",
    "Add roasted celery, lemon juice, orange juice, ginger, and stock. Bring to boil then reduce heat and simmer for 20 minutes.",
    "Blend soup with an immersion blender or transfer to a blender, blending in batches until smooth.",
    "Reheat the soup gently over medium-low heat. Taste for seasoning, adding more citrus juices if needed.",
    "Serve hot, garnished with cilantro leaves."
  ],
