{
  "title": "Crispy Sour Pineapple Salad",
  "description": "This low-sodium-friendly sour and crisp pineapple salad is perfect for a date night and features a sprinkle of dates to give it an Asian twist.",
  "cuisine": "Slovakian",
  "diet": [
    "low-sodium",
    "sugar-free"
  ],
