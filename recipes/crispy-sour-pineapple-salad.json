  "ingredients": [
    {
      "name": "Pineapple chunks",
      "amount": "1 cup"
    },
    {
      "name": "Date slices",
      "amount": "6-8, depending on preference for sweetness"
    },
    {
      "name": "Low-sodium soy sauce",
      "amount": "2 tablespoons"
    },
    {
      "name": "Lime juice",
      "amount": "3 tablespoons"
    },
    {
      "name": "Olive oil",
      "amount": "1 tablespoon"
    },
    {
      "name": "Minced garlic cloves",
      "amount": "1-2, depending on preference for spiciness"
    },
    {
      "name": "Cilantro leaves (optional)",
      "amount": "handful"
    }
  ],
  "instructions": [
    "Mix pineapples, date slices, soy sauce, lime juice, olive oil, and garlic in a large bowl.",
    "Toss well to ensure all ingredients are evenly coated.",
    "Transfer the mixture onto a baking dish and broil at 400°F for about 15 minutes or until the edges start to brown.",
    "Garnish with cilantro leaves if desired."
  ],
