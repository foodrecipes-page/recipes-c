      "name": "Juniper Berries",
      "amount": "1/4 cup fresh or 2 tbsp dried"
    },
    {
      "name": "Olive Oil",
      "amount": "3 tablespoons"
    },
    {
      "name": "Onion, finely chopped",
      "amount": "1 medium onion"
    },
    {
      "name": "Garlic, minced",
      "amount": "3 cloves"
    },
    {
      "name": "Tomato Sauce",
      "amount": "2 cups"
    },
    {
      "name": "Pistachios, crushed",
      "amount": "2 tablespoons"
    },
    {
      "name": "Herbes de Provence (optional)",
      "notes": "1 tablespoon"
    },
    {
      "name": "Fermented Herbs Mix (herb paste mix with fermented herbs and spices)",
      "amount": "3/4 cup"
    }
  ],
  "instructions": [
    "Heat olive oil in a skillet over medium heat.",
    "Add finely chopped onion and garlic, sauté until translucent.",
    "Stir in tomato sauce, cooked for about 5 minutes to reduce slightly.",
    "Fold in the crushed pistachios and herbes de Provence (if using).",
    "Combine with fermented herbs mix, stir well and cook for another minute.",
    "Adjust seasoning if needed and serve hot."
