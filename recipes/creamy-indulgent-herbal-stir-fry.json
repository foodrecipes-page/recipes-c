{
  "title": "Creamy Indulgent Herbal Stir-fry",
  "description": "A Mediterranean-friendly herbal stir-fry with juniper berries, fermented herbs and spices for a creamy indulgent Canadian dish.",
  "cuisine": "Canadian",
  "diet": [
    "vegetarian",
    "vegan"
  ],
