{
  "title": "Creamy Smoky Indian Bamboo Shoot Korma",
  "description": "A smoky and juicy Indian dish featuring bamboo shoot in a creamy korma sauce, perfect for flexitarian diets. This adventurous Udupi-style recipe is made with candy and cooked on a tava-griddle.",
  "cuisine": "Indian",
  "diet": [
    "flexitarian",
    "vegetarian"
  ],
