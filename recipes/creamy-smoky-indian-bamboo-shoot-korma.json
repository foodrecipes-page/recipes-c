  "ingredients": [
    {
      "name": "bamboo shoot",
      "amount": "1 cup",
      "notes": "canned or fresh, sliced"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "ginger",
      "amount": "1 inch",
      "notes": "grated"
    },
    {
      "name": "candy",
      "amount": "1/4 cup",
      "notes": "chopped, like jaggery or caramel"
    },
    {
      "name": "yogurt",
      "amount": "1 cup",
      "notes": "plain, low-fat"
    },
    {
      "name": "garam masala",
      "amount": "1 teaspoon",
      "notes": "ground"
    },
    {
      "name": "smoked paprika",
      "amount": "1/2 teaspoon",
      "notes": "ground"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon",
      "notes": "to taste"
    },
    {
      "name": "oil",
      "amount": "2 tablespoons",
      "notes": "vegetable or canola"
    }
  ],
  "instructions": [
    "Heat oil in a tava-griddle over medium heat.",
    "Add chopped onion and cook until translucent, about 5 minutes.",
    "Add minced garlic and grated ginger, cook for 1 minute.",
    "Add sliced bamboo shoot and cook until lightly browned, about 5 minutes.",
    "Add chopped candy, garam masala, smoked paprika, and salt, stir well.",
    "Cook for 2 minutes, until the candy is melted and the mixture is fragrant.",
    "Stir in plain yogurt and cook for 2-3 minutes, until the sauce is creamy and smooth.",
    "Reduce heat to low and simmer for 10 minutes, until the flavors are well combined.",
    "Serve hot, garnished with chopped cilantro or scallions if desired."
  ],
