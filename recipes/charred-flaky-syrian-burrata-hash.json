      "name": "1 head of cauliflower",
      "amount": "",
      "notes": "broken into florets"
    },
    {
      "name": "1 package of phyllo dough",
      "amount": "",
      "notes": "thawed"
    },
    {
      "name": "1 cup of burrata cheese",
      "amount": "",
      "notes": "cut into small pieces"
    },
    {
      "name": "2 tablespoons of olive oil",
      "amount": "",
      "notes": "for brushing phyllo"
    },
    {
      "name": "1 teaspoon of sumac",
      "amount": "",
      "notes": "Syrian spice blend"
    },
    {
