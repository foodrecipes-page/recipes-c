      "amount": "to taste"
    },
    {
      "name": "Black pepper",
      "amount": "to taste"
    },
    {
      "name": "Fresh parsley",
      "amount": "chopped (optional)"
    }
  ],
  "instructions": [
    "Heat 1 tablespoon olive oil in a large paella pan or skillet over medium-high heat.",
    "Add the chorizo and cook, stirring occasionally, until browned and crispy, about 4 minutes.",
    "Add the garlic and smoked paprika and cook for 1 minute, stirring constantly.",
    "Add the shrimp and cook until pink and just cooked through, about 2-3 minutes.",
    "Stir in the Thai fried rice, bay leaves, salt, and black pepper.",
    "Cook for 2-3 minutes, stirring constantly, until the rice is heated through and starting to brown.",
    "Drizzle with lemon juice and stir to combine.",
    "Remove from heat and garnish with chopped parsley if desired.",
    "Serve immediately and enjoy!"
  ],
