      "amount": "1 teaspoon"
    },
    {
      "name": "water",
      "amount": "4 cups"
    },
    {
      "name": "ice",
      "amount": "2 cups"
    }
  ],
  "instructions": [
    "Cut the bell peppers, onions, and zucchini into 1-inch pieces.",
    "Thread the vegetables onto skewers.",
    "In a bowl, mix together the fajita seasoning, lemon juice, and olive oil.",
    "Brush the mixture onto the vegetables.",
    "Heat a grill or grill pan to medium-high heat.",
    "Grill the skewers for 10 minutes, turning occasionally.",
    "Immediately plunge the skewers into an ice bath to stop the cooking process.",
    "Let the skewers sit in the ice bath for 5 minutes.",
    "Remove the skewers from the ice bath and sprinkle with salt.",
    "Serve the skewers immediately."
  ],
