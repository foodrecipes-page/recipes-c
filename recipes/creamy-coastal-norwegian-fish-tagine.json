{
  "title": "Creamy Coastal Norwegian Fish Tagine",
  "description": "A yeasty and velvety Norwegian dish featuring chimichurri sauce and ferment-jang, perfect for a festive pescatarian meal",
  "cuisine": "Norwegian",
  "diet": [
    "pescatarian"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "cod fillets",
      "amount": "4 pieces",
      "notes": "fresh and sustainably sourced"
    },
    {
      "name": "chimichurri sauce",
      "amount": "1 cup",
      "notes": "homemade or store-bought"
    },
    {
      "name": "ferment-jang",
      "amount": "2 tablespoons",
      "notes": "Korean fermented soybean paste"
    },
    {
      "name": "yeast",
      "amount": "1 teaspoon",
      "notes": "active dry yeast"
    },
    {
      "name": "heavy cream",
      "amount": "1 cup",
      "notes": "full fat"
    },
    {
      "name": "norwegian cheese",
      "amount": "1 cup",
      "notes": "such as Jarlsberg or Gudbrandsdalsost"
    },
    {
      "name": "fresh parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon",
      "notes": "to taste"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon",
      "notes": "to taste"
    }
  ],
  "instructions": [
    "Preheat the oven to 375 degrees Fahrenheit.",
    "Season the cod fillets with salt and black pepper.",
    "In a large tagine pot, combine the chimichurri sauce, ferment-jang, and yeast.",
    "Add the heavy cream and norwegian cheese to the tagine pot and stir until the cheese is melted.",
    "Add the cod fillets to the tagine pot and spoon some of the sauce over the top of each fillet.",
    "Cover the tagine pot with a lid and bake for 20 minutes.",
    "Remove the lid and continue baking for an additional 10 minutes.",
    "Sprinkle the chopped parsley over the top of the cod fillets and serve hot.",
    "Serve the creamy coastal norwegian fish tagine with crusty bread or over rice."
  ],
