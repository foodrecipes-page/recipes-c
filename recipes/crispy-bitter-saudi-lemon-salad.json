{
  "title": "Crispy Bitter Saudi Lemon Salad",
  "description": "A bright, crunchy salad that captures the nostalgic taste of Saudi Arabia with fresh unwaxed lemons, aromatic herbs, and a hint of bitter spice.",
  "cuisine": "Saudi Arabian",
  "diet": [
    "vegan",
    "gluten-free"
