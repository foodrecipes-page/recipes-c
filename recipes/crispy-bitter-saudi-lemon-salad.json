  "ingredients": [
    {
      "name": "unwaxed lemons",
      "amount": "2 medium",
      "notes": "thinly sliced into wedges"
    },
    {
      "name": "fresh parsley",
      "amount": "1 cup",
      "notes": "chopped"
    },
    {
      "name": "fresh mint",
      "amount": "1 cup",
      "notes": "chopped"
    },
    {
      "name": "red onion",
      "amount": "1/2 cup",
      "notes": "finely diced"
    },
    {
      "name": "toasted almonds",
      "amount": "2 tbsp",
      "notes": "chopped, toasted lightly"
    },
    {
      "name": "extra virgin olive oil",
      "amount": "1 tbsp",
      "notes": "room temperature"
    },
    {
      "name": "date syrup",
      "amount": "1 tbsp",
      "notes": "for natural sweetness"
    },
    {
      "name": "ground sumac",
      "amount": "1 tsp",
      "notes": "adds a tart, bitter note"
    },
    {
      "name": "ground cumin",
      "amount": "1/2 tsp",
      "notes": "warm flavor"
    },
    {
      "name": "sea salt",
      "amount": "1/4 tsp",
      "notes": "to taste"
    },
    {
      "name": "black pepper",
      "amount": "1/8 tsp",
      "notes": "freshly ground"
    }
  ],
  "instructions": [
    "Wash the lemons thoroughly and slice them into thin, bite‑sized wedges, leaving the rind on to preserve natural flavor and texture.",
    "In a large bowl, combine the chopped parsley, mint, diced onion, and toasted almonds.",
    "Add the lemon wedges to the herb mixture, gently tossing to coat.",
    "Drizzle the olive oil and date syrup over the salad, then sprinkle with sumac, cumin, salt, and pepper.",
    "Toss everything again until evenly seasoned and the lemon pieces are lightly coated.",
    "Serve immediately to enjoy the crisp, fresh crunch and the sharp, bitter citrus notes."
  ],
