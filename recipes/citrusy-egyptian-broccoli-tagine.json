{
  "title": "Citrusy Egyptian Broccoli Tagine",
  "description": "A fragrant, low‑fat tagine featuring tender purple sprouting broccoli, bright citrus juices, and aromatic spices that melt in the pot.",
  "cuisine": "Egyptian",
  "diet": [
    "low-fat",
    "vegetarian"
  ],
