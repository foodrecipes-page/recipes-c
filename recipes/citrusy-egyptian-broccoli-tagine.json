  "ingredients": [
    {
      "name": "Purple sprouting broccoli",
      "amount": "1 head (≈300g)",
      "notes": "cut into florets"
    },
    {
      "name": "Olive oil",
      "amount": "1 tbsp (15ml)",
      "notes": "low‑fat variant is fine"
    },
    {
      "name": "Fresh lemon",
      "amount": "1 (zest & juice)",
      "notes": "use whole fruit for juice"
    },
    {
      "name": "Fresh orange",
      "amount": "1 (juice)",
      "notes": "use whole fruit for juice"
    },
    {
      "name": "Garlic",
      "amount": "3 cloves, minced"
    },
    {
      "name": "Ground cumin",
      "amount": "1 tsp"
    },
    {
      "name": "Ground coriander",
      "amount": "1 tsp"
    },
    {
      "name": "Smoked paprika",
      "amount": "1 tsp"
    },
    {
      "name": "Salt",
      "amount": "1/2 tsp"
    },
    {
      "name": "Black pepper",
      "amount": "1/4 tsp"
    },
    {
      "name": "Chickpeas",
      "amount": "1 cup (canned, drained)",
      "notes": "adds protein"
    },
    {
      "name": "Fresh parsley",
      "amount": "2 tbsp chopped (plus 1 tbsp for garnish)"
    }
  ],
  "instructions": [
    "Rinse the broccoli and cut into florets, set aside.",
    "Whisk together lemon zest, lemon juice, orange juice, minced garlic, olive oil, cumin, coriander, paprika, salt, and pepper.",
    "Toss broccoli florets with the citrus mixture until well coated.",
    "Heat a heavy pot or tagine over medium heat; stir in the marinated broccoli and cook for 2 minutes.",
    "Add chickpeas, reduce heat to low, cover, and simmer 12–15 minutes until broccoli is tender.",
    "Stir occasionally; add a splash more lemon juice if desired.",
    "Transfer to a serving dish, sprinkle chopped parsley and extra lemon zest.",
    "Serve hot with couscous or flatbread."
  ],
