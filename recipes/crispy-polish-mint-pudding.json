  "ingredients": [
    {
      "name": "fresh mint leaves",
      "amount": "20g",
      "notes": "finely chopped"
    },
    {
      "name": "almond flour",
      "amount": "30g",
      "notes": "unsalted"
    },
    {
      "name": "coconut oil",
      "amount": "15ml",
      "notes": "melted"
    },
    {
      "name": "honey",
      "amount": "15ml",
      "notes": "raw"
    },
    {
      "name": "sodium bicarbonate",
      "amount": "5g",
      "notes": "for crispness"
    }
  ],
  "instructions": [
    "Heat coconut oil in a small pan over medium heat until melted.",
    "In a separate bowl, mix mint leaves and honey until combined.",
    "Add almond flour to the mint-honey mixture and stir until cohesive.",
    "Drizzle melted coconut oil over the mixture and mix well.",
    "Add sodium bicarbonate and mix gently to create a crisp texture.",
    "Spread the mixture on a baking sheet lined with parchment paper.",
    "Bake at 150°C for 10 minutes until crisp.",
    "Let cool for 5 minutes before serving."
  ],
