{
  "title": "Crispy Polish Mint Pudding",
  "description": "A light, nutty Polish dessert featuring fresh mint and a crisp base for a low-carb indulgence.",
  "cuisine": "polish",
  "diet": [
    "low-carb",
    "nutty",
    "indulgent"
