  "ingredients": [
    {
      "name": "Oreo cookies",
      "amount": "10"
    },
    {
      "name": "Orange juice concentrate",
      "amount": "1/4 cup"
    },
    {
      "name": "Lemon juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "Sour cream",
      "amount": "1/2 cup"
    },
    {
      "name": "Granulated sugar",
      "amount": "1/2 cup"
    },
    {
      "name": "Eggs",
      "amount": "3 eggs, beaten"
    }
  ],
  "instructions": [
    "Preheat oven to 400°F (205°C).",
    "Soak Oreo cookies in orange juice concentrate for about 2 hours.",
    "Drain excess liquid from soaked Oreos and mix with lemon juice, sour cream, and sugar until well combined.",
    "Gently fold in beaten eggs a couple of at a time.",
    "Spoon mixture into prepared mini muffin tins (about 1 tablespoon per cookie).",
    "Bake for 8-10 minutes or until edges are golden brown.",
    "Allow to cool slightly before removing from pan and serving."
  ],
