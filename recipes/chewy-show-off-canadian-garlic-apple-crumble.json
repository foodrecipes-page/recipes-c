{
  "title": "Chewy Show-off Canadian Garlic Apple Crumble",
  "description": "A show-off dish featuring a unique blend of braeburn apples, garlic, and a gluten-free crumble topping that is both chewy and garlic-infused.",
  "cuisine": "Canadian",
  "diet": null,
