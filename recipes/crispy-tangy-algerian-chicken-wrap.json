{
  "title": "Crispy Tangy Algerian Chicken Wrap",
  "description": "A high protein dish featuring crispy chicken and stir fry vegetables wrapped in a leaf and steamed, perfect for a sick day pick me up",
  "cuisine": "Algerian",
  "diet": [
    "high-protein",
