    {
      "name": "boneless chicken breast",
      "amount": "1 pound",
      "notes": "cut into thin strips"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "thinly sliced"
    },
    {
      "name": "bell pepper",
      "amount": "1 medium",
      "notes": "thinly sliced"
    },
    {
      "name": "garlic",
      "amount": "2 cloves",
      "notes": "minced"
    },
    {
      "name": "cumin",
      "amount": "1 teaspoon"
    },
    {
      "name": "paprika",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "collard green leaves",
      "amount": "4 large"
    }
  ],
  "instructions": [
    "Heat olive oil in a large skillet over medium high heat",
    "Add chicken to the skillet and cook until browned and cooked through",
    "Add onion and bell pepper to the skillet and cook until tender",
    "Add garlic, cumin, paprika, salt, and black pepper to the skillet and cook for 1 minute",
    "Lay a collard green leaf flat and place a quarter of the chicken and vegetable mixture in the center of the leaf",
    "Fold the stem end of the leaf over the filling, then fold in the sides and roll the leaf into a tight cylinder",
    "Repeat with the remaining leaves and filling",
    "Place the rolls in a steamer basket and steam for 5 minutes",
    "Serve hot and enjoy"
  ],
