  "instructions": [
    "heat the oil in a large clay pot over medium heat.",
    "add the onion and garlic and cook until the onion is translucent.",
    "add the red bell pepper and tomato and cook for an additional 2 minutes.",
    "add the rice and cook for 1 minute, stirring constantly.",
    "add the chicken broth and water, and bring to a boil.",
    "reduce the heat to low, cover the pot, and cook for 15 minutes.",
    "fluff the rice with a fork and season with salt and pepper.",
    "serve hot."
