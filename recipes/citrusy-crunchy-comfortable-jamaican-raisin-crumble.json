      "amount": "2 large"
    },
    {
      "name": "zest of 1 lemon",
      "notes": "plus juice"
    },
    {
      "name": "unsalted butter",
      "amount": "3/4 cup"
    },
    {
      "name": "honey or maple syrup",
      "amount": "1/4 cup"
    }
  ],
  "instructions": [
    "Preheat oven to 350°F (175°C). Grease a baking dish.",
    "Mix dried apricots, raisins, flour, cocoa powder, and cinnamon in a bowl until evenly distributed.",
    "In another bowl, whisk together eggs, lemon zest, vegetable oil, honey or maple syrup. Add to fruit mixture and mix well.",
    "Stir in unsalted butter chunks until mixture is moist but still crumbly.",
    "Press the mixture into the prepared baking dish and bake for 25-30 minutes or until edges are golden brown.",
    "Cool before slicing."
  ],
