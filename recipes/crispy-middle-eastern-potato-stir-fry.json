{
  "title": "Crispy Middle Eastern Potato Stir-fry",
  "description": "A crowd-pleasing Middle Eastern dish featuring crispy red potatoes that are perfectly balanced with umami flavors and a low-fat-friendly twist.",
  "cuisine": "Middle Eastern",
  "diet": [
    "low-fat"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "red potatoes",
      "amount": "2 large",
      "notes": "peeled and diced"
    },
    {
      "name": "olive oil",
      "amount": "3 tablespoons"
    },
    {
      "name": "garlic cloves",
      "amount": "4 cloves",
      "notes": "minced"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "sliced thinly"
    },
    {
      "name": "tomato paste",
      "amount": "2 tablespoons"
    },
    {
      "name": "soy sauce",
      "amount": "1/4 cup",
      "notes": "low-sodium variety preferred"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "paprika",
      "amount": "1 teaspoon"
    }
  ],
  "instructions": [
    "Heat olive oil in a large skillet over medium-high heat.",
    "Add garlic and onion, sauté for about 2 minutes until fragrant.",
    "Add diced potatoes to the skillet. Cook for about 5-7 minutes or until they start to brown slightly on the edges.",
    "Stir in tomato paste and cook for another minute until it starts to caramelize.",
    "Pour in soy sauce and lemon juice, reduce heat to low-medium and stir well.",
    "Sprinkle paprika over the top and let simmer for an additional 2-3 minutes.",
    "Serve hot as a side dish or on its own with some crusty bread."
  ],
