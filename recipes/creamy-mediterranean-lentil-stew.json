{
  "title": "Creamy Mediterranean Lentil Stew",
  "description": "A rich and comforting vegan stew featuring smoky paprika and kombu-cold-extract, perfect for a sick day. This fatty and velvety dish is sure to warm your belly and your heart.",
  "cuisine": "Mediterranean",
  "diet": [
    "vegan"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "red lentils",
      "amount": "1 cup",
      "notes": "rinsed and drained"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "smoky paprika",
      "amount": "1 teaspoon"
    },
    {
      "name": "kombu-cold-extract",
      "amount": "2 tablespoons"
    },
    {
      "name": "canned diced tomatoes",
      "amount": "1 can"
    },
    {
      "name": "vegetable broth",
      "amount": "4 cups"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large pot over medium heat.",
    "Add the chopped onion and cook until softened, about 5 minutes.",
    "Add the minced garlic and cook for an additional 1 minute.",
    "Add the smoky paprika and cook for 1 minute, stirring constantly.",
    "Add the rinsed lentils, kombu-cold-extract, diced tomatoes, vegetable broth, salt, and black pepper.",
    "Bring the mixture to a boil, then reduce the heat to low and simmer for 30 minutes.",
    "Use an immersion blender to puree the stew until smooth and creamy.",
    "Serve hot, garnished with chopped fresh herbs if desired."
  ],
