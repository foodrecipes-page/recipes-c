      "amount": "1 medium",
      "notes": "seeded and finely chopped"
    },
    {
      "name": "spinach",
      "amount": "2 cups fresh, washed and chopped"
    },
    {
      "name": "avocado",
      "amount": "1 ripe, diced"
    },
    {
      "name": "lime juice",
      "amount": "1 tbsp fresh"
    },
    {
      "name": "ginger",
      "amount": "1 inch, finely grated"
    },
    {
      "name": "cumin",
      "amount": "2 tsp ground"
    },
    {
      "name": "coriander seeds",
      "amount": "10 whole, lightly toasted and crushed"
    },
    {
      "name": "salt",
      "amount": "to taste"
    },
    {
      "name": "coconut oil",
      "amount": "2 tbsp"
    },
    {
      "name": "aloe vera gel",
      "amount": "2 tbsp (for texture only, not required for flavor)"
    },
    {
      "name": "pecans",
      "amount": "1/4 cup, finely chopped"
    }
  ],
  "instructions": [
    "Combine all ingredients except pecans in a mixing bowl.",
    "Mix well until all vegetables are fully coated with the herb mixture.",
    "Fold in pecans last for added texture and crunch.",
    "Transfer to an oven-safe dish and bake at 350°F (175°C) for about 25-30 minutes or until golden brown and crispy on top.",
