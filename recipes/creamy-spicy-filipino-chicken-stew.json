{
  "title": "Creamy Spicy Filipino Chicken Stew",
  "description": "A mild yet comforting chicken stew packed with coconut milk, sugarfree duck sauce, and a touch of heat-perfect for kids and adults alike.",
  "cuisine": "Filipino",
  "diet": [
    "sugar-free",
    "kid-friendly"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "boneless skinless chicken thighs",
      "amount": "1.5 lbs",
      "notes": "cut into 1\u00bd\" cubes"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "diced"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "ginger",
      "amount": "1-inch piece",
      "notes": "minced"
    },
    {
      "name": "red bell pepper",
      "amount": "1 medium",
      "notes": "sliced"
    },
    {
      "name": "coconut milk",
      "amount": "1 cup",
      "notes": "full\u2011fat"
    },
    {
      "name": "low\u2011sodium chicken broth",
      "amount": "1 cup",
      "notes": ""
    },
    {
      "name": "sugar\u2011free duck sauce",
      "amount": "2 tbsp",
      "notes": "use low\u2011sugar or homemade"
    },
    {
      "name": "soy sauce",
      "amount": "1 tbsp",
      "notes": "low\u2011sodium"
    },
    {
      "name": "sesame oil",
      "amount": "1 tsp",
      "notes": ""
    },
    {
      "name": "chili paste",
      "amount": "1 tsp",
      "notes": "sambal oelek or mild"
    },
    {
      "name": "cornstarch",
      "amount": "1 tbsp",
      "notes": "mixed with 1 tbsp water to make slurry"
    }
  ],
  "instructions": [
    "Heat the sesame oil in a Dutch oven over medium heat.",
    "Add onions, garlic, and ginger; saut\u00e9 until translucent, about 3 minutes.",
    "Add chicken cubes and brown on all sides, about 4\u20115 minutes.",
    "Stir in bell pepper and cook for another 2 minutes.",
    "Pour in coconut milk and chicken broth, bring to a gentle simmer.",
    "Add sugar\u2011free duck sauce, soy sauce, and chili paste; let flavors meld, simmer 15 minutes.",
    "Whisk the cornstarch slurry and stir into the stew; cook 2\u20113 minutes until thickened.",
    "Taste and season with salt if needed. Reduce heat to low and simmer 5 more minutes.\nServe hot over steamed rice or noodles."
  ],
