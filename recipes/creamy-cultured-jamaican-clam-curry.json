      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Heat the ghee in a terracotta dish over medium heat",
    "Add the diced onion and cook until translucent",
    "Add the minced garlic and grated ginger and cook for 1 minute",
    "Add the curry powder and cook for 1 minute, stirring constantly",
    "Add the coconut milk and bring to a simmer",
    "Add the clams and cook until they open",
    "Add the diced scotch bonnet pepper and cook for 1 minute",
    "Season with salt and black pepper to taste",
    "Serve hot, garnished with fresh cilantro"
  ],
