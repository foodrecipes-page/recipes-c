{
  "title": "Comfortable Flaky Herbs Crumble",
  "description": "A comforting Tunisian dish featuring malai, this paleo-friendly crumble is perfect for breakfast or a quick snack.",
  "cuisine": "Tunisian",
  "diet": [
    "paleo"
  ],
  "meal": "snack",
  "ingredients": [
    {
      "name": "Paleo-friendly almond flour",
      "amount": "1 cup"
    },
    {
      "name": "Peanut butter",
      "amount": "2 tablespoons"
    },
    {
      "name": "Almond milk",
      "amount": "1/4 cup"
    },
    {
      "name": "Coconut oil",
      "amount": "3 tablespoons"
    },
    {
      "name": "Malai (Indian style dairy-free cheese alternative)",
      "amount": "8 ounces"
    },
    {
      "name": "Turmeric powder",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "Cayenne pepper",
      "amount": "Pinch"
    },
    {
      "name": "Salt",
      "amount": "To taste"
    }
  ],
  "instructions": [
    "Preheat oven to 350°F (175°C).",
    "In a large bowl, mix together almond flour and peanut butter until well combined.",
    "Add in almond milk, coconut oil, malai, turmeric powder, cayenne pepper, and salt. Stir until crumbly mixture forms.",
    "Transfer the crumble to a greased baking dish (a 9x13 inch pan works well).",
    "Bake for 25-30 minutes or until golden brown on top and firm in texture.",
    "Allow it to cool before serving. Enjoy as is, with your favorite fruits, or use as an avocado topping."
  ],
