  "ingredients": [
    {
      "name": "1 cup chickpeas",
      "amount": "cup"
    },
    {
      "name": "2 tbsp olive oil",
      "amount": "tbsp"
    },
    {
      "name": "1 onion, chopped",
      "amount": "medium"
    },
    {
      "name": "2 garlic cloves, minced",
      "amount": "cloves"
    },
    {
      "name": "1-inch ginger, grated",
      "amount": "inch"
    },
    {
      "name": "1 tbsp garam masala powder",
      "amount": "tbsp"
    },
    {
      "name": "1/4 tsp turmeric powder",
      "amount": "tsp"
    },
    {
      "name": "1/2 tsp chili flakes (dried)",
      "amount": "tsp"
    },
    {
      "name": "1 can chickpea curry sauce",
      "amount": "can"
    },
    {
      "name": "Juice of 1 lemon",
      "amount": "juice"
    }
  ],
  "instructions": [
    "Heat olive oil in a pan over medium heat.",
    "Add onions, garlic, and ginger. Sauté until soft and translucent.",
    "Stir in garam masala powder and turmeric powder, cooking for another minute.",
    "Pour in the chickpea curry sauce and lemon juice. Bring to a boil.",
    "Reduce heat to low and simmer for 10 minutes to thicken the sauce.",
    "Add chickpeas to the pot and stir well to coat them evenly with the sauce.",
    "Simmer until most of the liquid has evaporated, about 5 more minutes.",
    "Serve hot as a meal-prep dish or as part of a main dinner course."
  ],
