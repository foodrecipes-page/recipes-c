      "amount": "1 teaspoon"
    },
    {
      "name": "coriander powder",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    }
  ],
  "instructions": [
    "Preheat the robata grill to 400 degrees Fahrenheit",
    "Thread the beef pieces onto skewers, leaving a small space between each piece",
    "In a bowl, mix together the coconut cream, yogurt, lemon juice, ghee, ginger paste, garlic paste, cumin powder, coriander powder, salt, and black pepper",
    "Brush the mixture onto the beef pieces",
    "Grill the kebabs for 10-12 minutes, turning occasionally",
    "Let the kebabs rest for 5 minutes before serving",
    "Serve the kebabs hot, garnished with fresh cilantro and a side of roasted vegetables"
  ],
