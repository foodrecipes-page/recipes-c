{
  "title": "Cozy Crunchy Canadian Seeds Crumble",
  "description": "An earthy and cozy Canadian-inspired dish featuring white wine and herbs for a plant-based breakfast or snack.",
  "cuisine": "Canadian",
  "diet": [
    "plant-based"
  ],
  "meal": "snack",
  "ingredients": [
    {
      "name": "Almonds",
      "amount": "1/2 cup"
    },
    {
      "name": "Walnuts",
      "amount": "1/4 cup"
    },
    {
      "name": "Cashews",
      "amount": "1/4 cup"
    },
    {
      "name": "Sunflower Seeds",
      "amount": "1/4 cup"
    },
    {
      "name": "White Wine",
      "amount": "2 tablespoons"
    },
    {
      "name": "Herbs (e.g., thyme, oregano)",
      "amount": "1 tablespoon each"
    },
    {
      "name": "Coconut Oil",
      "amount": "3 tablespoons"
    },
    {
      "name": "Salt",
      "amount": "a pinch"
    }
  ],
  "instructions": [
    "Preheat oven to 350°F (175°C).",
    "Toast almonds, walnuts, and cashews in a dry skillet over medium heat for about 2 minutes each, shaking the pan frequently.",
    "In a mixing bowl, combine toasted nuts with sunflower seeds. Add white wine, herbs, coconut oil, and salt. Mix well until all ingredients are evenly coated.",
    "Transfer mixture to a baking dish or shallow pan lined with parchment paper.",
    "Bake for 10-12 minutes until golden brown and crispy on the edges.",
    "Remove from oven and let cool slightly before serving."
  ],
