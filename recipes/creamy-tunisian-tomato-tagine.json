      "name": "fromage frais",
      "amount": "1 cup",
      "notes": "or substitute with plain greek yogurt"
    },
    {
      "name": "confit tomato",
      "amount": "2 cups",
      "notes": "homemade or store-bought"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "paprika",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    }
  ],
  "instructions": [
    "Heat the olive oil in a wok over medium heat.",
    "Add the chopped onion and cook until softened, about 5 minutes.",
    "Add the minced garlic and cook for an additional minute.",
    "Stir in the paprika, salt, and black pepper.",
    "Add the confit tomato and cook for 2 minutes, stirring occasionally.",
    "Stir in the fromage frais and lemon juice.",
    "Reduce heat to low and simmer, uncovered, for 10 minutes.",
    "Taste and adjust seasoning as needed.",
    "Serve hot, garnished with fresh parsley or cilantro."
  ],
