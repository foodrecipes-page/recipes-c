      "amount": "2 tablespoons"
    },
    {
      "name": "paprika",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "honey",
      "amount": "1 tablespoon"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large pot over medium heat.",
    "Add the chopped onion and cook until it is translucent.",
    "Add the minced garlic and cook for 1 minute.",
    "Add the chicken to the pot and cook until it is browned on all sides.",
    "Add the chicken broth, coconut milk, tomato paste, paprika, salt, and black pepper to the pot.",
    "Stir the mixture well and bring it to a boil.",
    "Reduce the heat to low and simmer the stew for 25 minutes.",
    "Stir in the honey until it is well combined.",
    "Serve the stew hot, garnished with chopped fresh herbs if desired."
  ],
