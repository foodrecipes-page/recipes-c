      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "coconut milk",
      "amount": "1 can"
    },
    {
      "name": "chicken broth",
      "amount": "2 cups"
    },
    {
