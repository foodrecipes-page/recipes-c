    },
    {
      "name": "olive oil",
      "amount": "1 tbsp",
      "notes": "for moisture and flavor"
    }
  ],
  "instructions": [
    "In a bowl, mix warm water, salt, and baking powder until dissolved.",
    "Add flour gradually, stirring until a shaggy dough forms.",
    "Knead for 5 minutes until smooth and elastic.",
    "Let rest for 10 minutes.",
    "Divide dough into 2 equal portions.",
    "Shape each portion into a ball, then flatten into thin discs.",
    "Heat a non-stick pan over medium heat with olive oil.",
    "Cook flatbreads for 2 minutes per side until golden and crispy.",
    "Serve warm, drizzled with a bit of olive oil for extra crunch."
