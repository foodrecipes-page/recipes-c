  "title": "Comforting Portuguese Baked Bean Stir-fry",
  "description": "A tangy, gooey comfort dish featuring baked beans with a high-protein twist, perfect for a comforting dinner.",
  "cuisine": "Portuguese",
  "diet": [
    "high-protein",
    "low-fat"
  ],
