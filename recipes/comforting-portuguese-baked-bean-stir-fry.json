  "ingredients": [
    {
      "name": "baked beans",
      "amount": "1 can (400g)",
      "notes": "drained and rinsed"
    },
    {
      "name": "ground turkey",
      "amount": "150g",
      "notes": "fully cooked, if desired"
    },
    {
      "name": "garlic cloves",
      "amount": "3",
      "notes": "minced"
    },
    {
      "name": "italian seasoning blend",
      "amount": "to taste"
    },
    {
      "name": "zucchini",
      "amount": "1 medium",
      "notes": "sliced into rounds"
    },
    {
      "name": "bell peppers",
      "amount": "2 large, any color",
      "notes": "halved and seeded"
    },
    {
      "name": "olive oil",
      "amount": "2 tbsp"
    }
  ],
  "instructions": [
    "Heat olive oil in a skillet over medium heat.",
    "Add minced garlic and cook for about 1 minute until fragrant but not browned.",
    "Add ground turkey to the skillet, breaking it up with a wooden spoon. Cook until fully cooked through, stirring occasionally.",
    "Stir in Italian seasoning blend and drained baked beans.",
    "Increase heat to medium-high and add sliced zucchini and bell peppers.",
    "Cook for about 5-7 minutes or until vegetables are tender but still have some crunchiness.",
    "Serve hot with crusty bread if desired."
  ],
