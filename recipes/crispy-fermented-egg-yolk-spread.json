{
  "title": "Crispy Fermented Egg Yolk Spread",
  "description": "A Mediterranean-inspired spread that combines fermented egg yolks with crispy textures for a unique and nutritious treat suitable for egg-free diets.",
  "cuisine": "Mediterranean",
  "diet": [
    "vegan",
    "gluten-free"
