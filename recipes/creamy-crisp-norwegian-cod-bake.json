{
  "title": "Creamy Crisp Norwegian Cod Bake",
  "description": "A tangy and creamy weeknight Norwegian dish featuring palm sugar and coconut cream.",
  "cuisine": "Norwegian",
  "diet": [
    "gluten-free"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "4 Cod fillets",
      "amount": "6 oz",
      "notes": "Fresh or frozen, thawed"
    },
    {
      "name": "1/4 cup Palm sugar",
      "amount": "",
      "notes": "Or brown sugar"
    },
    {
      "name": "1/2 cup Coconut cream",
      "amount": "",
      "notes": "Full-fat, refrigerated"
    },
    {
      "name": "2 tablespoons Butter",
      "amount": "",
      "notes": "Unsalted"
    },
    {
      "name": "2 cloves Garlic",
      "amount": "",
      "notes": "Minced"
    },
    {
      "name": "1/2 cup White wine",
      "amount": "",
      "notes": "Dry"
    },
    {
      "name": "1/4 cup Fish broth",
      "amount": "",
      "notes": "Homemade or store-bought"
    },
    {
      "name": "2 tablespoons Fresh parsley",
      "amount": "",
      "notes": "Chopped"
    },
    {
      "name": "1 teaspoon Dill weed",
      "amount": "",
      "notes": "Fresh or dried"
    }
  ],
  "instructions": [
    "Preheat the oven to 400°F (200°C).",
    "Line a baking sheet with parchment paper or aluminum foil.",
    "Season the cod fillets with salt and pepper.",
    "In a large skillet, melt 1 tablespoon of butter over medium-high heat.",
    "Add the cod fillets and cook for 2-3 minutes per side, until browned.",
    "Transfer the cod to the prepared baking sheet.",
    "In the same skillet, melt the remaining 1 tablespoon of butter over medium heat.",
    "Add the garlic, white wine, fish broth, palm sugar, and dill weed.",
    "Bring the mixture to a simmer and cook for 2-3 minutes, until slightly reduced.",
    "Stir in the coconut cream.",
    "Pour the creamy sauce over the cod fillets.",
    "Sprinkle with parsley and bake for 10-12 minutes, until the cod is cooked through and the sauce is bubbly.",
    "Serve hot and enjoy!"
  ],
