    },
    {
      "name": "Fresh parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Preheat the robata grill to 400 degrees Fahrenheit.",
    "In a bowl, whisk together olive oil, garlic, lemon juice, salt, black pepper, and paprika.",
    "Add the pitted Turkish black olives to the bowl and toss to coat with the marinade.",
    "Thread 2-3 olives onto each bamboo skewer.",
    "Brush the grill with olive oil to prevent sticking.",
    "Grill the olive skewers for 2-3 minutes per side, or until crispy and charred.",
    "Serve the skewers hot, garnished with chopped fresh parsley.",
    "Let the skewers cool for a minute or two before serving.",
    "Serve immediately and enjoy."
  ],
