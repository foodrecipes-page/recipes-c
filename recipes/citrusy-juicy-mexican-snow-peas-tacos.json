{
  "title": "Citrusy Juicy Mexican Snow Peas Tacos",
  "description": "A fresh, tangy taco filling that pairs juicy snow peas with marinated halal beef and bright citrus, finished with pickled jalapeños for a burst of flavor.",
  "cuisine": "Mexican",
  "diet": [
    "halal"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "halal beef sirloin, sliced thin",
      "amount": "1 lb (450 g)"
    },
    {
      "name": "snow peas, trimmed",
      "amount": "1 cup (150 g)"
    },
    {
      "name": "fresh cucumber, diced",
      "amount": "1/2 cup (75 g)",
      "notes": "for a mild crunch"
    },
    {
      "name": "pickled jalapeño slices",
      "amount": "1/4 cup (40 g)"
    },
    {
      "name": "lime, juiced",
      "amount": "1 lime"
    },
    {
      "name": "orange, juiced",
      "amount": "1/2 orange"
    },
    {
      "name": "fresh cilantro, chopped",
      "amount": "2 tbsp (8 g)",
      "notes": "for garnish"
    },
    {
      "name": "olive oil",
      "amount": "1 tbsp (15 ml)"
    },
    {
      "name": "ground cumin",
      "amount": "1 tsp (3 g)",
      "notes": "for marination"
    },
    {
      "name": "smoked paprika",
      "amount": "1 tsp (3 g)"
    },
    {
      "name": "chili powder",
      "amount": "1/2 tsp (1.5 g)"
    },
    {
      "name": "corn tortillas",
      "amount": "8 small tortillas"
    }
  ],
  "instructions": [
    "Whisk together lime juice, orange juice, cumin, smoked paprika, chili powder, salt, and pepper in a bowl.",
    "Add beef slices to the bowl, toss to coat, and let marinate for 10 minutes.",
    "Heat a skillet over medium-high and add olive oil.",
    "Sear beef slices for 3-4 minutes per side until cooked through; remove and set aside.",
    "In the same skillet, sauté snow peas for 2 minutes until tender-crisp.",
    "Warm corn tortillas on a dry skillet or microwave for 15 seconds.",
    "Assemble tacos: place snow peas on each tortilla, top with beef, sprinkle cucumber and jalapeño slices, drizzle with leftover citrus mixture, and garnish with cilantro.",
    "Serve immediately with lime wedges on the side."
  ],
