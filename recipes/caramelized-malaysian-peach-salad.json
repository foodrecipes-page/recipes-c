{
  "title": "Caramelized Malaysian Peach Salad",
  "description": "A floral and light dessert featuring smoked paprika, perfect for kids and keto-friendly.",
  "cuisine": "Malaysian",
  "diet": [
    "keto"
  ],
  "meal": "dessert",
  "ingredients": [
    {
      "name": "Peaches",
      "amount": "4 medium"
    },
    {
      "name": "Almond Flour",
      "amount": "2 tablespoons"
    },
    {
      "name": "Vanilla Bean Powder",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "Brown Sugar",
      "amount": "1 tablespoon"
    },
    {
      "name": "Cinnamon Powder",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "Smoked Paprika",
      "amount": "1/8 teaspoon"
    },
    {
      "name": "EVOO (Extra Virgin Olive Oil)",
      "amount": "2 tablespoons"
    }
  ],
  "instructions": [
    "Preheat oven to 350°F.",
    "Cut peaches into wedges and remove pits. Place in a baking dish.",
    "In a small bowl, mix almond flour, vanilla bean powder, brown sugar, cinnamon, and smoked paprika until combined.",
    "Drizzle the mixture evenly over each peach wedge and brush with EVOO on top.",
    "Bake for 15 minutes or until peaches are tender and slightly caramelized. Let cool before serving."
  ],
