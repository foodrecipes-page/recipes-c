{
  "title": "Crispy Resinous Tunisian Fish Brik",
  "description": "A crispy, lazy-sunday dish featuring molasses and coconut cream, perfect for a pescatarian-friendly lunch.",
  "cuisine": "tunisian",
  "diet": [
    "pescatarian",
    "vegetarian"
