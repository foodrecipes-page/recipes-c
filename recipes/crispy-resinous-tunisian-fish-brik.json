  "ingredients": [
    {
      "name": "Flour",
      "amount": "2 cups",
      "notes": "All-purpose flour"
    },
    {
      "name": "Water",
      "amount": "1 cup",
      "notes": "Room temperature water"
    },
    {
      "name": "Salt",
      "amount": "1/2 teaspoon",
      "notes": "Fine salt"
    },
    {
      "name": "Sugar",
      "amount": "1 tablespoon",
      "notes": "Granulated sugar"
    },
    {
      "name": "Molasses",
      "amount": "2 tablespoons",
      "notes": "Dark molasses"
    },
    {
      "name": "Coconut Oil",
      "amount": "1/4 cup",
      "notes": "Melted coconut oil"
    },
    {
      "name": "Shredded Coconut",
      "amount": "1/2 cup",
      "notes": "Shredded dried coconut"
    },
    {
      "name": "Canned Sardines",
      "amount": "1 can",
      "notes": "Drained and chopped sardines"
    },
    {
      "name": "Egg",
      "amount": "1",
      "notes": "Beaten egg"
    },
    {
      "name": "Brik Pastry",
      "amount": "1 package",
      "notes": "Frozen brik pastry"
    }
  ],
  "instructions": [
    "Heat the coconut oil in a small pan over medium heat.",
    "In a large bowl, combine the flour, water, salt, sugar, and molasses. Mix until a dough forms.",
    "Knead the dough for 5 minutes until it becomes smooth and elastic.",
    "Roll out the dough to a thickness of 1/4 inch.",
    "Using a cookie cutter or the rim of a glass, cut out circles of dough.",
    "Place a tablespoon of shredded coconut on one half of each circle.",
    "Top the coconut with a few pieces of chopped sardines.",
    "Fold the other half of the dough over the filling, pressing the edges to seal.",
    "Heat a non-stick pan or griddle over medium heat.",
    "Cook the brik for 2-3 minutes on each side, until crispy and golden brown.",
    "Serve the brik hot with a side of yogurt or tahini sauce."
  ],
