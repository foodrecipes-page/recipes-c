{
  "title": "Caramelized Juicy Chicken Stir-fry",
  "description": "This low-carb-friendly Ukrainian dish features tender chicken that is caramelized and served with a side of herbs for an indulgent yet herbal and juicy taste.",
  "cuisine": "Ukrainian",
  "diet": [
    "low-carb"
  ],
