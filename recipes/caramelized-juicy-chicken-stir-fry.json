  "ingredients": [
    {
      "name": "Boneless Chicken Breast",
      "amount": "4 pieces"
    },
    {
      "name": "Lemon Juice",
      "amount": "1/2 cup"
    },
    {
      "name": "Olive Oil",
      "amount": "3 tablespoons"
    },
    {
      "name": "Garlic Powder",
      "amount": "1 tablespoon"
    },
    {
      "name": "Salt",
      "amount": "to taste"
    },
    {
      "name": "Black Pepper",
      "amount": "to taste"
    },
    {
      "name": "Herbs (e.g. Thyme, Rosemary)",
      "amount": "a few sprigs"
    }
  ],
  "instructions": [
    "Preheat your oven to 350°F (175°C).",
    "Slice the chicken breasts into thin strips.",
    "Whisk together lemon juice, olive oil, garlic powder, salt, and black pepper in a bowl. Add the chicken strips to the mixture and toss until well coated.",
    "Place the chicken on an oven-safe baking sheet lined with parchment paper.",
    "Bake for 15 minutes or until golden brown and crispy on top.",
    "Remove from oven and let cool slightly before serving with fresh herbs."
  ],
