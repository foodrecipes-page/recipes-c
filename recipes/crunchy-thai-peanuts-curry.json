      "amount": "2 cloves, minced"
    },
    {
      "name": "ginger",
      "amount": "1 tbsp, grated"
    },
    {
      "name": "red bell pepper",
      "amount": "1, sliced"
    },
    {
      "name": "broccoli florets",
      "amount": "1 cup"
    },
    {
      "name": "unsweetened coconut milk",
      "amount": "1/2 cup"
    },
    {
