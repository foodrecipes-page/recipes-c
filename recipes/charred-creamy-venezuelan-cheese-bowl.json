{
  "title": "Charred Creamy Venezuelan Cheese Bowl",
  "description": "A festive Venezuelan dish featuring charred cheese, HP sauce, and shio cure, served in a Korean brass bowl, with a vegan friendly option.",
  "cuisine": "Venezuelan",
  "diet": [
    "vegan",
    "gluten-free"
  ],
