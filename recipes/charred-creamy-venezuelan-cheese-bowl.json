    {
      "name": "Vegan mozzarella",
      "amount": "1 cup",
      "notes": "shredded"
    },
    {
      "name": "HP sauce",
      "amount": "1/4 cup"
    },
    {
      "name": "Shio cure",
      "amount": "2 tbsp"
    },
    {
      "name": "Olive oil",
      "amount": "2 tbsp"
    },
    {
      "name": "Red onion",
      "amount": "1/2 cup",
      "notes": "thinly sliced"
    },
    {
      "name": "Bell pepper",
      "amount": "1/2 cup",
      "notes": "diced"
    },
    {
      "name": "Cilantro",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "Salt",
      "amount": "1 tsp"
    },
    {
      "name": "Black pepper",
      "amount": "1 tsp"
    },
    {
      "name": "Korean chili flakes",
      "amount": "1 tsp"
    }
  ],
  "instructions": [
    "Preheat the oven to 400 degrees Fahrenheit.",
    "In a large bowl, whisk together HP sauce and shio cure.",
    "Add the shredded vegan mozzarella to the bowl and mix until well coated.",
    "Heat the olive oil in a large skillet over medium high heat.",
    "Add the sliced red onion and diced bell pepper to the skillet and cook until charred.",
    "Add the cooked onion and bell pepper to the bowl with the cheese mixture and stir to combine.",
    "Season with salt, black pepper, and Korean chili flakes.",
    "Transfer the mixture to a Korean brass bowl and bake in the preheated oven for 15 minutes.",
    "Remove from the oven and top with chopped cilantro.",
    "Serve hot and enjoy."
  ],
