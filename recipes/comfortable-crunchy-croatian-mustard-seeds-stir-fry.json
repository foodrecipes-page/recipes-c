{
  "title": "Comfortable Crunchy Croatian Mustard Seeds Stir-fry",
  "description": "A comforting and tangy dish featuring mustard powder, knead and jain-friendly, perfect for a quick meal.",
  "cuisine": "Croatian",
  "diet": [
    "jain-friendly"
  ],
  "meal": "snack",
  "ingredients": [
    {
      "name": "Mustard Powder",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "Sunflower Seeds",
      "amount": "3 tablespoons",
      "notes": "Knead until the seeds are coated with powder"
    },
    {
      "name": "Jaggery (Gur)",
      "amount": "1 tablespoon"
    },
    {
      "name": "Sesame Oil",
      "amount": "2 teaspoons"
    },
    {
      "name": "Vegetable Oil",
      "amount": "1 teaspoon"
    },
    {
      "name": "Fresh Mint Leaves",
      "amount": "6-8 fresh leaves"
    },
    {
      "name": "Coriander (Cilantro) Leaves",
      "amount": "few sprigs"
    },
    {
      "name": "Crushed Red Chili Peppers",
      "amount": "1-2, to taste"
    }
  ],
  "instructions": [
    "Heat sesame oil and vegetable oil in a pan over medium heat.",
    "Add mustard powder and knead until the seeds are well coated.",
    "Pour in jaggery and mix thoroughly until it melts into the mixture.",
    "Stir in mint leaves, coriander leaves, and crushed red chili peppers. Cook for an additional minute.",
    "Serve hot with a side of rice or bread."
  ],
