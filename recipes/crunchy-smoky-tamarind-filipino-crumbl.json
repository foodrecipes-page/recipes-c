{
  "title": "Crunchy Smoky Tamarind Filipino Crumbl",
  "description": "A light Filipino crumbly dish featuring fermented tamarind paste with a smoky kick from sichuan pepper and served as a savory snack or breakfast treat.",
  "cuisine": "Filipino",
  "diet": null,
  "meal": "snack",
  "ingredients": [
    {
      "name": "fermented tamarind paste",
      "amount": "1/4 cup"
    },
    {
      "name": "all-purpose flour",
      "amount": "2 cups"
    },
    {
      "name": "all-purpose flour (for dusting)",
      "amount": "1 tablespoon"
    },
    {
      "name": "sichuan peppercorns",
      "amount": "2 teaspoons"
    },
    {
      "name": "sesame seeds",
      "amount": "1/4 cup"
    },
    {
      "name": "tamarind concentrate syrup",
      "amount": "3 tablespoons"
    },
    {
      "name": "vegetable oil",
      "amount": "2 tablespoons"
    }
  ],
  "instructions": [
    "Preheat oven to 180\u00b0C (350\u00b0F).",
    "Mix all ingredients in a large bowl until smooth and well combined.",
    "Form the mixture into small balls, about golf ball size, then dust with additional flour on both sides.",
    "Place the crumbls on a baking sheet lined with parchment paper.",
    "Broil for 10 minutes or until golden brown.",
    "Remove from oven and let cool slightly before serving."
