{
  "title": "Creamy Spicy Mediterranean Lamb Tagine",
  "description": "A spicy and creamy Mediterranean dish featuring lamb, this tagine is a crowd-pleaser. It is made with lamb stock and a lacquer-glaze, and is kosher-friendly.",
  "cuisine": "Mediterranean",
  "diet": [
    "kosher"
  ],
