  "ingredients": [
    {
      "name": "lamb shoulder",
      "amount": "1 1/2 pounds",
      "notes": "cut into 2 inch pieces"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 large",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "ground cumin",
      "amount": "1 teaspoon"
    },
    {
      "name": "smoked paprika",
      "amount": "1 teaspoon"
    },
    {
      "name": "cayenne pepper",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "lamb stock",
      "amount": "2 cups"
    },
    {
      "name": "heavy cream",
      "amount": "1 cup"
    },
    {
      "name": "dried apricots",
      "amount": "1/2 cup",
      "notes": "chopped"
    },
    {
      "name": "fresh parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Heat the olive oil in a large Dutch oven over medium-high heat.",
    "Add the lamb pieces and cook until browned on all sides, about 5 minutes.",
    "Add the chopped onion and cook until it is softened, about 5 minutes.",
    "Add the minced garlic and cook for 1 minute.",
    "Stir in the cumin, smoked paprika, and cayenne pepper, and cook for 1 minute.",
    "Add the lamb stock and bring to a boil.",
    "Reduce the heat to low and simmer, covered, for 1 1/2 hours.",
    "Stir in the heavy cream and chopped apricots, and cook for an additional 30 minutes.",
    "Season with salt and pepper to taste.",
    "Garnish with chopped parsley and serve over couscous."
  ],
