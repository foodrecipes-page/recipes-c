      "amount": "1/3 cup"
    },
    {
      "name": "baking powder",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "unsalted butter",
      "amount": "5 tbsp, softened"
    },
    {
      "name": "sugar",
      "amount": "2 tablespoons"
    },
    {
      "name": "lime juice",
      "amount": "1 tablespoon"
    },
    {
      "name": "orange zest",
      "amount": "1 tablespoon"
    },
    {
      "name": "bhuna spices mix (cumin seeds, coriander powder)",
      "amount": "to taste"
    },
    {
      "name": "chopped fresh mint leaves",
      "amount": "a few"
    }
  ],
  "instructions": [
    "Preheat oven to 350°F (175°C).",
    "Combine flour and baking powder in a bowl. Add softened butter, sugar, lime juice, orange zest, and bhuna spices mix into the dry ingredients.",
    "Mix until crumbly texture is achieved. Stir in chopped mint leaves for extra flavor.",
    "Press mixture onto a greased 9-inch square pan.",
    "Bake for about 15-20 minutes or until golden brown. Let it cool before serving."
