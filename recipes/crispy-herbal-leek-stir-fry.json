{
  "title": "Crispy Herbal Leek Stir-fry",
  "description": "A nostalgic Croatian dish featuring crispy leeks and a blend of herbal flavors that is vegan-friendly and packed with nutrients.",
  "cuisine": "Hellenic, Croatian",
  "diet": [
    "vegan"
  ],
  "meal": "lunch",
  "ingredients": [
    {
      "name": "500g leeks",
      "amount": "whole"
    },
    {
      "name": "2 tbsp olive oil",
      "notes": "or any other plant-based oil"
    },
    {
      "name": "1 tsp dried oregano"
    },
    {
      "name": "1 tsp dried basil"
    },
    {
      "name": "1 tsp dried thyme"
    },
    {
      "name": "Salt and pepper to taste"
    },
    {
      "name": "2 cloves garlic, minced"
    },
    {
      "name": "Juice of 1 lemon"
    }
  ],
  "instructions": [
    "Wash leeks thoroughly and slice them into thin strips.",
    "Heat oil in a wok or large skillet over medium-high heat.",
    "Add leeks to the wok and cook until they become translucent, about 5 minutes.",
    "Stir in minced garlic and herbs. Cook for another minute until fragrant.",
    "Squeeze lemon juice over the leeks. Season with salt and pepper.",
    "Serve hot as a side dish or over rice."
  ],
