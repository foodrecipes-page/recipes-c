      "name": "ground annatto",
      "amount": "1 tsp"
    },
    {
      "name": "garlic cloves",
      "amount": "6 cloves, minced"
    },
    {
      "name": "italian parsley leaves",
      "amount": "2 tbsp, chopped"
    },
    {
      "name": "red bell peppers",
      "amount": "1 medium, diced"
    },
    {
      "name": "green onions",
      "amount": "2 pieces, sliced thinly"
    },
    {
      "name": "soy sauce",
      "amount": "1 tbsp"
    },
    {
      "name": "vegetable oil",
      "amount": "2 tbsp"
    },
    {
      "name": "salt",
      "amount": "to taste"
    }
  ],
  "instructions": [
    "Heat vegetable oil in a wok or large skillet over medium heat.",
    "Add ground annatto and minced garlic, stir-fry for about 1 minute until fragrant.",
    "Add red bell peppers and green onions to the pan; stir until just softened.",
    "Stir in chopped parsley and soy sauce. Season with salt as needed.",
    "Cook until ingredients are heated through and combined evenly.",
    "Remove from heat and serve hot or at room temperature."
  ],
