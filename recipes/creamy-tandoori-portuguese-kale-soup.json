{
  "title": "Creamy Tandoori Portuguese Kale Soup",
  "description": "A fragrant, creamy kale soup spiced with tandoori masala, brightened by pickled cucumbers and finished with coconut milk—kid‑friendly and Whole30‑approved.",
  "cuisine": "Portuguese",
  "diet": [
    "whole30",
    "vegetarian",
    "kid-friendly"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "olive oil",
      "amount": "2 tbsp",
      "notes": "extra‑virgin, for sautéing"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "diced"
    },
    {
      "name": "garlic",
      "amount": "2 cloves",
      "notes": "minced"
    },
    {
      "name": "fresh ginger",
      "amount": "1 tbsp",
      "notes": "grated"
    },
    {
      "name": "tandoori masala",
      "amount": "2 tbsp",
      "notes": "Whole30‑friendly blend"
    },
    {
      "name": "kale",
      "amount": "1 cup",
      "notes": "chopped, stems removed"
    },
    {
      "name": "pickled cucumber",
      "amount": "1 cup",
      "notes": "sliced into thin rings"
    },
    {
      "name": "vegetable broth",
      "amount": "4 cups",
      "notes": "low-sodium"
    },
    {
      "name": "coconut milk",
      "amount": "1 cup",
      "notes": "full-fat"
    },
    {
      "name": "lemon juice",
      "amount": "2 tsp",
      "notes": "freshly squeezed"
    },
    {
      "name": "salt",
      "amount": "to taste",
      "notes": "optional"
    },
    {
      "name": "fresh cilantro",
      "amount": "2 tbsp",
      "notes": "chopped, for garnish"
    }
  ],
  "instructions": [
    "Heat olive oil in a large pot over medium heat.",
    "Add diced onion and sauté until translucent, about 3 minutes.",
    "Stir in minced garlic, grated ginger, and tandoori masala; cook for 1 minute until fragrant.",
    "Add chopped kale and sliced pickled cucumber, cooking for another 2 minutes, stirring to combine.",
    "Pour in vegetable broth and bring to a gentle simmer. Cook for 10 minutes, allowing the kale to soften.",
    "Stir in coconut milk and lemon juice, then simmer for an additional 5 minutes.",
    "Season with salt to taste. Remove from heat.",
    "Using an immersion blender, blend the soup until silky smooth, or leave slightly chunky if preferred.",
    "Serve hot, garnished with chopped cilantro."
  ],
