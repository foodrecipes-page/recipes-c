      "name": "boneless chicken breasts",
      "amount": "200g",
      "notes": "cut into thin strips"
    },
    {
      "name": "cherry tomatoes",
      "amount": "150g",
      "notes": "halved"
    },
    {
      "name": "shredded carrots",
      "amount": "100g"
    },
    {
      "name": "green onions (scallions)",
      "amount": "2",
      "notes": "finely chopped"
    },
    {
      "name": "tofu",
      "amount": "100g",
      "notes": "crumbled"
    },
    {
      "name": "v Sterbottensost cheese",
      "amount": "50g",
      "notes": "softened and gently tempered"
    },
    {
