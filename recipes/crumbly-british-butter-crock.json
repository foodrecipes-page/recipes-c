  "ingredients": [
    {
      "name": "1 cup heavy cream",
      "amount": "1"
    },
    {
      "name": "2 tablespoons unsalted butter",
      "amount": "2"
    },
    {
      "name": "Pinch of kosher salt"
    },
    {
      "name": "1/4 cup red wine"
    },
    {
      "name": "3 cloves garlic, minced"
    },
    {
      "name": "Juice of 1 lemon"
    }
  ],
  "instructions": [
    "Preheat your oven to 350°F (175°C).",
    "In a mixing bowl, combine the heavy cream and garlic. Mix until smooth.",
    "Add the unsalted butter, red wine, salt, and lemon juice into the mixture. Stir well until fully combined.",
    "Transfer the mixture into an oven-safe crockpot or pot.",
    "Cover with the lid and cook for 30 minutes on high heat or until thickened to your desired consistency.",
    "Serve hot as a weeknight comfort food."
