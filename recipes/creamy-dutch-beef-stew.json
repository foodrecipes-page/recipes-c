{
  "title": "Creamy Dutch Beef Stew",
  "description": "A fresh and velvety weeknight Dutch dish featuring mixed beef cuts, this stew is a lacto-vegetarian friendly option, excluding the beef for vegetarians and using candy-like sweet ingredients",
  "cuisine": "Dutch",
  "diet": [
    "lacto-vegetarian"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "beef stew meat",
      "amount": "1 pound",
      "notes": "mixed cuts"
    },
    {
      "name": "butter",
      "amount": "2 tablespoons"
    },
    {
      "name": "onions",
      "amount": "1 medium"
    },
    {
      "name": "carrots",
      "amount": "2 medium"
    },
    {
      "name": "potatoes",
      "amount": "2 medium"
    },
    {
      "name": "all-purpose flour",
      "amount": "2 tablespoons"
    },
    {
      "name": "beef broth",
      "amount": "2 cups"
    },
    {
      "name": "heavy cream",
      "amount": "1 cup"
    },
    {
      "name": "brown sugar",
      "amount": "1 tablespoon",
      "notes": "candy-like sweet ingredient"
    },
    {
      "name": "dried thyme",
      "amount": "1 teaspoon"
    }
  ],
  "instructions": [
    "Heat the butter in a large Dutch oven over medium heat",
    "Add the beef and cook until browned on all sides",
    "Add the onions, carrots, and potatoes, and cook until the vegetables are tender",
    "Add the flour and cook for 1 minute",
    "Add the beef broth, heavy cream, brown sugar, and thyme, and stir to combine",
    "Bring the mixture to a boil, then reduce the heat to low and simmer for 30 minutes",
    "Season with salt and pepper to taste",
    "Serve hot"
  ],
