    },
    {
      "name": "black pepper",
      "amount": "to taste",
      "notes": "freshly ground"
    },
    {
      "name": "butter or vegan alternative",
      "amount": "2 tablespoons",
      "notes": "such as Earth Balance"
    }
  ],
  "instructions": [
    "Preheat the oven to 400°F (200°C).",
    "Heat the olive oil in an oven-safe skillet over medium heat. Add the garlic and cook for 1-2 minutes, until fragrant.",
    "Add the chives to the skillet and cook for 2-3 minutes, until they start to soften.",
    "Pour in the lemon juice and cook for an additional 2 minutes, until the chives are tender.",
    "Season the chives with salt and black pepper to taste.",
    "Add the butter or vegan alternative to the skillet and stir until melted.",
    "Transfer the skillet to the preheated oven and cook for 5-7 minutes, until the chives are caramelized.",
    "Remove the skillet from the oven and let it cool slightly before serving."
  ],
