    },
    {
      "name": "lemon juice",
      "amount": "2 tablespoons",
      "notes": "freshly squeezed"
    },
    {
      "name": "olive oil",
      "amount": "2 tablespoons",
      "notes": "high-quality"
    },
    {
      "name": "salt",
      "amount": "to taste",
