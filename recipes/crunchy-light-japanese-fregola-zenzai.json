      "amount": "1/2 cup"
    },
    {
      "name": "green onions",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "sesame seeds",
      "amount": "1 tablespoon"
    },
    {
      "name": "salt",
      "amount": "1/4 teaspoon"
    }
  ],
  "instructions": [
    "Toast the fregola in a dry pan over medium heat until lightly browned.",
    "Cut the double-rise-bread into small cubes and toast until crispy.",
    "In a large bowl, whisk together the sesame oil, soy sauce, and salt.",
    "Add the toasted fregola, bread cubes, grated daikon, and green onions to the bowl and toss to combine.",
    "Spoon the mixture into a bamboo steamer lined with parchment paper.",
    "Sprinkle the sesame seeds over the top of the mixture.",
    "Steam the zenzai over boiling water for 5 minutes.",
    "Serve the zenzai hot, garnished with additional green onions if desired."
  ],
