      "notes": "toasted"
    },
    {
      "name": "double-rise-bread",
      "amount": "2 slices",
      "notes": "cubed"
    },
    {
      "name": "sesame oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "soy sauce",
      "amount": "1 tablespoon"
    },
    {
