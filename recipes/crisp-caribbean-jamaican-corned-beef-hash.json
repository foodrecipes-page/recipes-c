  "ingredients": [
    {
      "name": "corned beef",
      "amount": "1 can",
      "notes": "drained and diced"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "bell pepper",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "scotch bonnet pepper",
      "amount": "1",
      "notes": "chopped"
    },
    {
      "name": "potato",
      "amount": "2 medium",
      "notes": "peeled and diced"
    },
    {
      "name": "vegetable oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Heat the oil in a large skillet over medium heat",
    "Add the chopped onion and saute until softened",
    "Add the chopped bell pepper and scotch bonnet pepper and saute for 2 minutes",
    "Add the diced corned beef and cook until browned",
    "Add the diced potato and cook until they start to brown",
    "Use a spatula to press down on the mixture and form a crispy crust",
    "Flip the hash over and cook for an additional 2 minutes",
    "Season with salt and pepper to taste",
    "Serve hot and enjoy"
  ],
