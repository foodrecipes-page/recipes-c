{
  "title": "Crisp Caribbean Jamaican Corned Beef Hash",
  "description": "A tangy and crisp Jamaican dish featuring corned beef, perfect for a weeknight dinner, and is lacto-vegetarian-friendly",
  "cuisine": "Jamaican",
  "diet": [
    "lacto-vegetarian"
  ],
