{
  "title": "Comforting Canadian Butternut Squash Stew",
  "description": "A citrusy and creamy Canadian dish featuring red wine and tadka, perfect for a cold winter night. This stew is Jain-friendly and suitable for a weeknight dinner.",
  "cuisine": "Canadian",
  "diet": null,
