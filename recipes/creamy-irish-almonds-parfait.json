{
  "title": "Creamy Irish Almonds Parfait",
  "description": "A light, low-fat parfait rich with toasted flaked almonds and creamy yogurt, perfect for meal-prep.",
  "cuisine": "Irish",
  "diet": [
    "vegetarian",
    "low-fat"
  ],
