{
  "title": "Crispy Tangy Shortening Pilaf",
  "description": "A diabetic-friendly Slovakian dish featuring shortening for a crispy texture and tangy flavors, prepared with minimal added sugars.",
  "cuisine": "Slovakian",
  "diet": [
    "diabetic-friendly"
  ],
  "meal": "dinner",
  "ingredients": [
