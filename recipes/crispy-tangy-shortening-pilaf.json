      "name": "shortening",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion, finely chopped",
      "amount": "1 medium"
    },
    {
      "name": "garlic clove, minced",
      "amount": "1"
    },
    {
      "name": "canned crushed tomatoes",
      "amount": "14 oz can (about 50g)"
    },
    {
      "name": "water",
      "amount": "2 cups"
    },
    {
      "name": "salt",
      "amount": "to taste"
    },
    {
      "name": "pepper",
      "amount": "to taste"
    },
    {
      "name": "unsweetened applesauce",
      "amount": "1/4 cup"
    }
  ],
  "instructions": [
    "Preheat oven to 375°F (190°C).",
    "In a large skillet, melt the shortening over medium heat.",
    "Add onion and garlic; sauté until soft, about 3 minutes.",
    "Pour in crushed tomatoes with their juice, add water, salt, pepper, and unsweetened applesauce. Stir well to combine.",
    "Transfer mixture into an oven-safe dish that can withstand high temperatures (like glass or ceramic).",
    "Bake at 375°F (190°C) for about 20 minutes or until the edges start to crisp up.",
    "Let it cool slightly before serving."
  ],
