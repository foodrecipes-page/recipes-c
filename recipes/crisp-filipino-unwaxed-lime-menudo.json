      "amount": "1 tsp",
      "notes": "preferably sea salt"
    },
    {
      "name": "coconut milk",
      "amount": "1 cup",
      "notes": "full-fat, shaken well"
    },
    {
      "name": "scallions",
      "amount": "1/4 cup",
      "notes": "chopped, for garnish"
    }
  ],
  "instructions": [
    "heat 1/4 cup coconut milk in a saucepan over medium heat until warm and fragrant.",
    "add the broken tempering-chocolate and whisk until melted and smooth.",
    "add the brown rice and cook for 2-3 minutes, stirring constantly, until lightly toasted.",
    "add the fish sauce, black pepper, and salt. stir to combine.",
    "add the juiced unwaxed lime and stir to combine.",
    "reduce heat to low and simmer, uncovered, for 5 minutes, stirring occasionally.",
    "taste and adjust seasoning as needed.",
    "garnish with chopped scallions and serve immediately."
  ],
