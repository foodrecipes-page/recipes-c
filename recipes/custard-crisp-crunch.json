{
  "title": "Custard Crisp Crunch",
  "description": "A salty and crispy Filipino dish featuring custard powder that's perfect for weeknight meals, gluten-free-friendly.",
  "cuisine": "Filipino",
  "diet": [
    "gluten-free"
  ],
  "meal": "snack",
  "ingredients": [
    {
      "name": "custard powder",
      "amount": "2 tablespoons"
    },
    {
      "name": "flour",
      "amount": "1/4 cup"
    },
    {
      "name": "baking powder",
      "amount": "1/8 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "vegetable oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "coconut flakes",
      "amount": "1 cup"
    },
    {
      "name": "brown sugar",
      "amount": "1/3 cup"
    },
    {
      "name": "almond flour",
      "amount": "1/4 cup (for dusting, optional)"
    },
    {
      "name": "water",
      "amount": "2 cups"
    }
  ],
  "instructions": [
    "Preheat oven to 350\u00b0F (180\u00b0C).",
    "Mix custard powder, flour, baking powder, and salt in a bowl.",
    "Add oil, coconut flakes, brown sugar, and enough water to make a thick batter. Mix well until smooth.",
    "Pour the mixture into an ungreased 9x13 inch pan. Sprinkle almond flour evenly over the top for extra crunch if desired.",
    "Bake for 25-30 minutes or until golden brown. Let cool slightly before serving.",
    "Serve with a side of your choice."
  ],
