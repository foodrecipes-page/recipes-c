      "name": "Dark Brown Sugar",
      "amount": "1/2 cup"
    },
    {
      "name": "Coconut Oil",
      "amount": "1 tablespoon"
    },
    {
      "name": "Vanilla Extract",
      "amount": "1 teaspoon"
    },
    {
      "name": "Almond Meal",
      "amount": "1/4 cup"
    },
    {
      "name": "Baking Powder",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "Sea Salt",
      "amount": "1/8 teaspoon"
    }
  ],
  "instructions": [
    "Preheat oven to 350\u00b0F (175\u00b0C).",
    "Mix dark brown sugar, coconut oil, vanilla extract until smooth.",
    "Stir in almond meal and baking powder. Mix well but avoid overmixing as it will make the crumble tough.",
    "Fold in sea salt gently.",
    "Transfer mixture to a greased muffin pan (one for each crumble).",
    "Bake for 10-15 minutes or until golden brown on top.",
    "Allow to cool slightly before serving."
