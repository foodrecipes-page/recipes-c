{
  "title": "Crispy Citrus Saudi Arabian Chicken Kebabs",
  "description": "A romantic, citrus-infused chicken kebab brushed with garam masala and grilled to a crisp finish in a tandoor-style oven.",
  "cuisine": "Saudi Arabian",
  "diet": null,
  "meal": "dinner",
  "ingredients": [
    {
      "name": "Boneless skinless chicken thighs",
      "amount": "800g",
      "notes": "cut into 2cm cubes"
    },
    {
      "name": "Plain Greek yogurt",
      "amount": "½ cup",
      "notes": "for marination"
    },
    {
      "name": "Fresh lemon juice",
      "amount": "3 tbsp",
      "notes": "grated zest optional"
    },
    {
      "name": "Fresh orange juice",
      "amount": "2 tbsp",
      "notes": "for sweetness"
    },
    {
      "name": "Garam masala",
      "amount": "1 tsp"
    },
    {
      "name": "Ground cumin",
      "amount": "1 tsp"
    },
    {
      "name": "Ground coriander",
      "amount": "1 tsp"
    },
    {
      "name": "Smoked paprika",
      "amount": "½ tsp"
    },
    {
      "name": "Turmeric powder",
      "amount": "¼ tsp"
    },
    {
      "name": "Cayenne pepper",
      "amount": "¼ tsp"
    },
    {
      "name": "Sea salt",
      "amount": "1 tsp"
    },
    {
      "name": "Black pepper",
      "amount": "½ tsp"
    },
    {
      "name": "Garlic cloves, minced",
      "amount": "2",
      "notes": "optional"
    }
  ],
  "instructions": [
    "In a large bowl combine yogurt, lemon juice, orange juice, garam masala, cumin, coriander, paprika, turmeric, cayenne, salt, pepper, and minced garlic.",
    "Add chicken cubes to the bowl, ensuring each piece is thoroughly coated. Cover and refrigerate for at least 1 hour, preferably 3–4 hours for deeper flavor.",
    "Preheat a grill or oven to 220 °C (428 °F). Thread marinated chicken onto skewers, spacing pieces slightly to allow even cooking.",
    "Brush each skewer lightly with olive oil; grill or bake for 10–12 minutes, turning every 3 minutes, until the chicken is cooked through (internal temperature 74 °C / 165 °F) and edges are crisp.",
    "Remove from heat, sprinkle with fresh lemon zest, and serve hot with a side of plain couscous or flatbread."
  ],
