      "name": "1 can of sweet corn",
      "amount": "one can"
    },
    {
      "name": "2 medium ripe avocados",
      "amount": "two"
    },
    {
      "name": "4 tablespoons of lemon juice",
      "amount": "four tablespoons"
    },
    {
      "name": "3 cloves of garlic, minced",
      "amount": "three cloves"
    },
    {
      "name": "1/2 cup of fresh parsley leaves",
      "amount": "half a cup"
    },
    {
      "name": "Salt and pepper to taste",
      "notes": "For seasoning"
    },
    {
      "name": "Oregano for garnish (optional)",
      "notes": "Fresh or dried, use sparingly"
    }
  ],
  "instructions": [
    "Peel the avocados and cut them into cubes.",
    "Mince the garlic cloves.",
    "In a mixing bowl, combine the avocado cubes with lemon juice, minced garlic, and salt and pepper to taste. Mix thoroughly until well combined.",
    "Add the sweet corn can into the bowl with the avocados, mix again.",
    "Fold in fresh parsley leaves gently without overmixing to maintain texture.",
    "Garnish with fresh oregano if desired.",
    "Serve immediately or store refrigerated for up to 24 hours."
