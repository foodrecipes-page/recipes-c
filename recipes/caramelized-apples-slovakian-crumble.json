{
  "title": "Caramelized Apples Slovakian Crumble",
  "description": "An earthy and flaky brunch dish featuring caramelize apples with a low-calorie-friendly crumble topping made from oat flour.",
  "cuisine": "Slovakian",
  "diet": [
    "low-calorie-friendly"
  ],
