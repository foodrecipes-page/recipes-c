  "ingredients": [
    {
      "name": "Oat Flour",
      "amount": "1/4 cup"
    },
    {
      "name": "Honey",
      "amount": "1 tablespoon"
    },
    {
      "name": "Unsweetened Apple Sauce",
      "amount": "1/2 cup"
    },
    {
      "name": "Cinnamon",
      "amount": "1 teaspoon"
    },
    {
      "name": "Almond Flour",
      "amount": "1/4 cup"
    },
    {
      "name": "Walnut Pieces",
      "amount": "2 tablespoons"
    },
    {
      "name": "Eggs",
      "amount": "3, lightly beaten"
    },
    {
      "name": "Grated Apple",
      "amount": "6 apples"
    },
    {
      "name": "Cider Vinegar",
      "amount": "1 teaspoon"
    }
  ],
  "instructions": [
    "Preheat oven to 400°F (205°C). Grease a baking dish.",
    "Mix oat flour, honey, apple sauce, cinnamon, and almond flour in a bowl. Stir in lightly beaten eggs and grated apples.",
    "Pour mixture into the prepared baking dish. Sprinkle walnut pieces on top.",
    "Combine cider vinegar with unsweetened apple sauce to make a glaze. Drizzle over crumble.",
    "Bake for 25-30 minutes, until golden brown and set.",
    "Let cool before serving."
  ],
