{
  "title": "Crunchy Smoky Venezuelan Smoked Turkey Neck Empanadas",
  "description": "A twist on traditional Venezuelan empanadas, featuring smoky turkey neck and crunchy texture from toasted plantain.",
  "cuisine": "Venezuelan",
  "diet": [
    "keto"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "Smoked Turkey Neck",
      "amount": "4 pieces",
      "notes": "Smoked in-house or store-bought"
    },
    {
      "name": "Toasted Plantain",
      "amount": "2 cups",
      "notes": "Peel and chop"
    },
    {
      "name": "Venezuelan Cheese",
      "amount": "1 cup",
      "notes": "Queso fresco or similar"
    },
    {
      "name": "Onion",
      "amount": "1 cup",
      "notes": "Chopped"
    },
    {
      "name": "Garlic",
      "amount": "3 cloves",
      "notes": "Minced"
    },
    {
      "name": "Olive Oil",
      "amount": "1/4 cup",
      "notes": "Infused with smoked paprika"
    },
    {
      "name": "Egg",
      "amount": "1",
      "notes": "Beaten"
    },
    {
      "name": "Water",
      "amount": "1 cup",
      "notes": "For dough"
    },
    {
      "name": "Flour",
      "amount": "2 cups",
      "notes": "All-purpose flour"
    },
    {
      "name": "Salt",
      "amount": "1 tsp",
      "notes": "To taste"
    }
  ],
  "instructions": [
    "Preheat oven to 375°F.",
    "In a food processor, blend toasted plantain, Venezuelan cheese, onion, and garlic until well combined.",
    "In a separate bowl, mix smoked turkey neck, egg, and infused olive oil.",
    "Add the turkey mixture to the plantain mixture and blend until well combined.",
    "In a large bowl, combine flour and salt.",
    "Gradually add water to the flour mixture and knead for 10 minutes.",
    "Divide the dough into 8 equal pieces and shape into balls.",
    "Roll out each ball of dough into a thin circle.",
    "Place a tablespoon of the turkey mixture in the center of each dough circle.",
    "Fold the dough over the filling and press edges to seal.",
    "Brush tops with a little water and bake for 20 minutes.",
    "Serve warm and enjoy!"
  ],
