    },
    {
      "name": "beers",
      "amount": "1 bottle of non-alcoholic beer or 1/4 cup dry white wine"
    },
    {
      "name": "vegetable oil",
      "amount": "2 tbsp"
    }
  ],
  "instructions": [
    "Heat vegetable oil in a large skillet over medium-high heat.",
    "Add onions and garlic, sauté until translucent, about 3 minutes.",
    "Stir in smoked paprika and red pepper flakes, cook for another minute.",
    "Pour in tomatoes and simmer for 5-7 minutes or until slightly thickened.",
    "Gently fold in olives and vegan cheese (if using).",
    "Reduce heat to low, add beer. Stir occasionally until the sauce has reduced to your desired consistency, about 10 minutes.",
    "Serve hot with crusty bread."
