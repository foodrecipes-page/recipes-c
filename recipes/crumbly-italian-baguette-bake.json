    },
    {
      "name": "fresh basil",
      "amount": "20g",
      "notes": "chopped"
    },
    {
      "name": "olive oil",
      "amount": "15ml",
      "notes": "extra virgin"
    }
  ],
  "instructions": [
    "Preheat oven to 200°C (400°F).",
    "Slice baguette into 1cm thick rounds.",
    "In a small bowl, mix butter, olive oil, and chopped basil until combined.",
    "Place baguette rounds in a greased baking dish, then sprinkle with grated parmesan.",
    "Pour the butter-oil-basil mixture over the baguette.",
    "Bake for 15-18 minutes until golden and crisp.",
    "Let cool for 5 minutes before serving."
  ],
