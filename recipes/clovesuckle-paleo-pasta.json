      "name": "Garlic cloves",
      "amount": "2-3, minced"
    },
    {
      "name": "Onion",
      "amount": "1 medium, finely chopped"
    },
    {
      "name": "Olive oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "Red pepper flakes",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "Kalamata olives",
      "amount": "6-8, pitted and halved"
    },
    {
      "name": "Clove of garlic (for garnish)",
      "amount": "1 whole, unpeeled"
    }
  ],
  "instructions": [
    "Preheat your sous-vide machine to 130°F.",
    "Place the paleo pasta in a bowl. Add minced garlic and finely chopped onion over the pasta.",
    "Drizzle with olive oil and add red pepper flakes. Mix well until combined.",
    "Fold in pitted kalamata olives. Taste test and adjust seasoning as needed.",
    "Transfer the mixture to a serving dish.",
    "Top each serving with one whole, unpeeled garlic clove for garnish (optional)."
