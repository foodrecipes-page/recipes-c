{
  "title": "Crunchy Sweet and Nostalgic Walnut Crumble",
  "description": "A sweet and gooey Turkish dish featuring dry white wine, toast, egg-free-friendly with a crunchy walnut crumble topping.",
  "cuisine": "Turkish",
  "diet": [
    "vegan",
    "gluten-free"
