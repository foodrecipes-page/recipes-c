  "ingredients": [
    {
      "name": "60g walnuts",
      "amount": "grams"
    },
    {
      "name": "150ml dry white wine",
      "amount": "milliliters"
    },
    {
      "name": "150g dates",
      "amount": "grams",
      "notes": "pitted and chopped"
    },
    {
      "name": "150g figs",
      "amount": "grams",
      "notes": "chopped"
    },
    {
      "name": "40g unsalted butter, melted",
      "amount": "grams",
      "notes": "at room temperature"
    },
    {
      "name": "30ml honey or agave syrup",
      "amount": "milliliters",
      "notes": "adjust to taste"
    }
  ],
  "instructions": [
    "Preheat oven to 180°C (350°F).",
    "Toast walnuts in a dry pan over medium heat until golden brown, about 4 minutes.",
    "In a bowl, mix walnuts with chopped dates and figs. Add white wine, honey or agave syrup, and melted butter; toss to combine.",
    "Press walnut mixture firmly into the bottom of a greased dish (18x12cm).",
    "Bake for 15 minutes until golden and crisp on top.",
    "Serve warm as a dessert. Store leftovers in an airtight container in the fridge for up to 3 days."
  ],
