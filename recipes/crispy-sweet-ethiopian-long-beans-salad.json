{
  "title": "Crispy Sweet Ethiopian Long Beans Salad",
  "description": "A quick, lowcarb salad that blends crisp Chinese long beans with a sweet berberespiced glaze for a refreshing Ethiopian-inspired bite.",
  "cuisine": "Ethiopian",
  "diet": [
    "low-carb",
    "vegetarian"
  ],
  "meal": "lunch",
  "ingredients": [
    {
      "name": "Chinese long beans (yardlong beans)",
      "amount": "300g",
      "notes": "trimmed and cut into 2-inch pieces"
    },
    {
      "name": "Coconut sugar",
      "amount": "1 tbsp",
      "notes": "or erythritol for a lower carb option"
    },
    {
      "name": "Berbere spice",
      "amount": "1 tsp",
      "notes": "adjust to taste"
    },
    {
      "name": "Fresh ginger",
      "amount": "1 tsp",
      "notes": "grated"
    },
    {
      "name": "Garlic",
      "amount": "1 clove",
      "notes": "minced"
    },
    {
      "name": "Rice vinegar",
      "amount": "1 tbsp",
      "notes": "adds tang"
    },
    {
      "name": "Sesame oil",
      "amount": "1 tbsp",
      "notes": "for stir\u2011frying"
    },
    {
      "name": "Fresh lime",
      "amount": "1",
      "notes": "juiced"
    },
    {
      "name": "Salt",
      "amount": "pinch",
      "notes": "to taste"
    },
    {
      "name": "Sesame seeds",
      "amount": "1 tbsp",
      "notes": "toasted"
    },
    {
      "name": "Fresh cilantro",
      "amount": "2 tbsp",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Wash and trim the long beans, cutting them into 2\u2011inch pieces.",
    "Heat 1 tsp sesame oil in a skillet over medium\u2011high heat.",
    "Add berbere, ginger, and garlic; saut\u00e9 for 30 seconds until fragrant.",
    "Add the long beans and stir\u2011fry for 4\u20135 minutes until crisp\u2011tender.",
    "Stir in coconut sugar, rice vinegar, and lime juice; cook for 1 minute until the sugar melts and the beans are coated.",
    "Remove from heat and let the beans rest for 2 minutes.",
    "Season with a pinch of salt and sprinkle toasted sesame seeds over the top.",
    "Toss in chopped cilantro for freshness.",
    "Serve immediately, either warm or at room temperature."
  ],
