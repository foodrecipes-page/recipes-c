    {
      "name": "Cilantro",
      "amount": "chopped, for garnish"
    }
  ],
  "instructions": [
    "Heat sesame oil in a large saucepan over medium heat.",
    "Add chopped onion and cook until softened, about 5 minutes.",
    "Add grated galangal and cook for 1 minute.",
    "Add fish sauce and cook for 1 minute.",
    "Pour in coconut milk and bring to a simmer.",
    "Reduce heat to low and let cook for 10 minutes.",
    "Stir in gorgonzola dolce until melted and smooth.",
    "Season with salt and black pepper to taste.",
    "Ladle bisque into individual mini cocottes and garnish with chopped cilantro."
