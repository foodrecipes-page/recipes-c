{
  "title": "Caramelized Vietnamese Sirloin Stir-fry",
  "description": "A meal-prep-friendly dish featuring tender sirloin steak tips that are caramelized to perfection and packed with herbs for a delicious paleo option.",
  "cuisine": "Vietnamese",
