      "name": "Paleo-friendly Sirloin Steak Tips",
      "amount": "10 oz"
    },
    {
      "name": "Water chestnuts",
      "amount": "1/4 cup"
    },
    {
      "name": "Pork cracklings (lardons)",
      "amount": "15 pieces"
    },
    {
      "name": "Green onions",
      "amount": "2 stalks, sliced"
    },
    {
      "name": "Soy sauce",
      "amount": "3 tbsp"
    },
    {
      "name": "Fish Sauce",
      "amount": "3 tbsp"
    },
    {
      "name": "White pepper",
      "amount": "1 tsp"
    },
    {
      "name": "Ginger (grated)",
      "amount": "1 inch"
    }
  ],
  "instructions": [
    "Heat oil in a non-stick pan over medium-high heat.",
    "Add soy sauce, fish sauce, white pepper, and ginger to the pan. Stir well until it becomes dark brown and glossy.",
    "Gently place sirloin steak tips into the pan, then add water chestnuts and pork cracklings on top of the steak.",
    "Stir-fry for about 5 minutes or until the steak is golden brown and cooked through. Add sliced green onions to finish.",
    "Remove from heat and serve immediately."
  ],
