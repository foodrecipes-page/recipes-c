      "amount": "1 tsp (2 g)",
      "notes": null
    },
    {
      "name": "ground cumin",
      "amount": "1/2 tsp (1 g)",
      "notes": null
    },
    {
      "name": "ground turmeric",
      "amount": "1/4 tsp (0.5 g)",
      "notes": null
    },
    {
