{
  "title": "Crispy Smoky Jamaican Coconut Fritters",
  "description": "A kid-friendly, nutfree Jamaican fritter that combines smoky coconut batter with a touch of appleton rum and spiced bhuna seasoning for a crispy, flavorful snack.",
  "cuisine": "Jamaican",
  "diet": [
    "vegan"
  ],
  "meal": "snack",
  "ingredients": [
    {
      "name": "all-purpose flour",
      "amount": "1 cup (120 g)",
      "notes": null
    },
    {
      "name": "baking powder",
      "amount": "1 tsp (4 g)",
      "notes": null
    },
    {
