{
  "title": "Chewy Egyptian Herb Crumble",
  "description": "A vegan-friendly and chewy herbal crumble that is perfect for a weeknight dinner featuring shredded Mexican cheese.",
  "cuisine": "Egyptian",
  "diet": [
    "vegan"
  ],
  "meal": "dessert",
  "ingredients": [
    {
      "name": "coconut flour",
      "amount": "1 cup"
    },
    {
      "name": "chia seeds",
      "amount": "2 tbsp"
    },
    {
      "name": "unsweetened shredded Mexican cheese",
      "amount": "4 oz"
    },
    {
      "name": "honey or maple syrup",
      "amount": "3 tbsp"
    },
    {
      "name": "apple cider vinegar",
      "amount": "1 tsp"
    },
    {
      "name": "salt",
      "amount": "1/2 tsp"
    },
    {
      "name": "ground coriander",
      "amount": "1 tsp"
    },
    {
      "name": "paprika",
      "amount": "1 tsp"
    }
  ],
  "instructions": [
    "Preheat oven to 350°F (175°C).",
    "In a mixing bowl, combine coconut flour, chia seeds, shredded cheese, honey or maple syrup, apple cider vinegar, salt, ground coriander, and paprika.",
    "Mix well until the mixture is crumbly but holds together when pressed. It should be easily spreadable but slightly chunky.",
    "Press the mixture into a lined baking dish.",
    "Bake for 15 minutes or until golden brown on top. Let cool before serving."
  ],
