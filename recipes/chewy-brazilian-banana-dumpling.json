{
  "title": "Floral Chewy Banana Dumpling",
  "description": "A whole30-friendly dessert that combines bananas and other fruits to create a chewy base with floral notes suitable for hangover-cures.",
  "cuisine": "Brazilian",
  "diet": [
    "whole30"
  ],
  "meal": "dessert",
  "ingredients": [
    {
      "name": "ripe bananas",
      "amount": "2 medium"
    },
    {
      "name": "dates",
      "amount": "10 medium",
      "notes": "soaked in water for 30 minutes"
    },
    {
      "name": "chopped nuts (almond, cashew)",
      "amount": "2 tablespoons each",
      "notes": "for added texture and flavor"
    },
    {
      "name": "coconut flakes",
      "amount": "1/4 cup"
    },
    {
      "name": "maple syrup or honey",
      "amount": "3 tablespoons"
    }
  ],
  "instructions": [
    "Mash bananas in a bowl with dates, soaking nuts, coconut flakes, and maple syrup until smooth.",
    "Fold in mashed bananas mixture into the dates mixture until evenly combined.",
    "Shape the mixture into small dumplings using your hands or a cookie scoop.",
    "Place dumplings on a baking sheet lined with parchment paper.",
    "Bake at 350°F (175°C) for about 20 minutes, or until golden brown.",
    "Allow to cool and enjoy."
  ],
