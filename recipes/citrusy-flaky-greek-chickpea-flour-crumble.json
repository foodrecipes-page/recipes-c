  "ingredients": [
    {
      "name": "1 cup Greek yogurt",
      "amount": "cup"
    },
    {
      "name": "1/2 cup chickpea flour (also known as gram flour or besan)",
      "amount": "cup"
    },
    {
      "name": "1 tablespoon grated fresh orange zest",
      "amount": ""
    },
    {
      "name": "1 teaspoon finely ground cinnamon",
      "amount": "teaspoon"
    },
    {
      "name": "Pinch of sea salt",
      "amount": ""
    },
    {
      "name": "2 tablespoons honey or stevia (optional)",
      "amount": "tablespoons"
    },
    {
      "name": "1/4 cup freshly squeezed orange juice",
      "amount": "cup"
    }
  ],
  "instructions": [
    "In a bowl, mix together the Greek yogurt, chickpea flour, orange zest, cinnamon, and salt.",
    "Add honey or stevia to taste if using (optional).",
    "Stir in the freshly squeezed orange juice until well combined.",
    "Transfer the mixture onto a baking sheet lined with parchment paper.",
    "Bake at 350\u00b0F for 12-15 minutes, or until golden and crispy on top. Keep an eye to prevent burning.",
    "Let cool slightly before serving."
  ],
