{
  "title": "Citrusy Flaky Greek Chickpea Flour Crumble",
  "description": "This light and citrusy dish combines chickpea flour with a touch of sweetness from honey for an easy breakfast or snack option that's perfect for those watching their sugar intake.",
  "cuisine": "Greek",
  "diet": [
    "sugar-free-friendly"
  ],
