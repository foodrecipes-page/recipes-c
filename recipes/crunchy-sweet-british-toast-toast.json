{
  "title": "Crunchy Sweet British Toast",
  "description": "A sweet and crunchy British dish made with toasted bread, topped with a mixture of seeds and spices, perfect for a quick snack or breakfast.",
  "cuisine": "British",
  "diet": null,
  "meal": "breakfast",
  "ingredients": [
    {
      "name": "Whole wheat bread",
      "amount": "2 slices",
      "notes": ""
    },
    {
      "name": "Canola oil",
      "amount": "1/4 cup",
      "notes": "For toasting the bread"
    },
    {
      "name": "Pumpkin seeds",
      "amount": "2 tablespoons",
      "notes": "For added crunch"
    },
    {
      "name": "Sunflower seeds",
      "amount": "2 tablespoons",
      "notes": "For added crunch"
    },
    {
      "name": "Honey",
      "amount": "2 tablespoons",
      "notes": "For sweetness"
    },
    {
      "name": "Cinnamon powder",
      "amount": "1/4 teaspoon",
      "notes": "For flavor"
    },
    {
      "name": "Salt",
      "amount": "a pinch",
      "notes": "To balance flavors"
    },
    {
      "name": "Almond butter",
      "amount": "2 tablespoons",
      "notes": "Optional, for added flavor"
    },
    {
      "name": "Fresh berries",
      "amount": "1 cup",
      "notes": "Optional, for added sweetness"
    }
  ],
  "instructions": [
    "Preheat a non-stick pan or griddle over medium heat.",
    "Add the canola oil to the pan and swirl it around to coat the bottom.",
    "Place the bread slices in the pan and toast until golden brown, flipping halfway through.",
    "In a small bowl, mix together the pumpkin seeds, sunflower seeds, honey, cinnamon powder, and salt.",
    "Once the bread is toasted, top each slice with a quarter of the seed mixture.",
    "If using almond butter, spread a tablespoon on top of the seed mixture.",
    "If using fresh berries, place a few on top of the almond butter or seed mixture.",
    "Repeat the process with the remaining ingredients to make the remaining toast slices.",
    "Serve warm and enjoy!"
  ],
