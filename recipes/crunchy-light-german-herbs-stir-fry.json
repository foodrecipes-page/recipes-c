      "amount": "2 cloves, minced"
    },
    {
      "name": "Herbs (e.g., parsley, dill)",
      "amount": "1 tablespoon dried or 2 tablespoons fresh, chopped"
    },
    {
      "name": "Sesame Seeds (optional for garnish)",
