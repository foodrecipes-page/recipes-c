      "name": "peanut oil",
      "amount": "2 tablespoons",
      "notes": "for cooking"
    },
    {
      "name": "onion",
      "amount": "1 large",
      "notes": "chopped"
    },
    {
      "name": "carrots",
      "amount": "2 medium",
      "notes": "peeled and chopped"
    },
    {
      "name": "zucchini",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "bell pepper",
      "amount": "1 large",
      "notes": "chopped"
    },
    {
      "name": "basmati rice",
      "amount": "1 cup",
      "notes": "rinsed and drained"
    },
    {
      "name": "vegetable broth",
      "amount": "2 cups",
      "notes": "low sodium"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon",
      "notes": "or to taste"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon",
      "notes": "or to taste"
    },
    {
      "name": "fresh parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Heat the peanut oil in a large saucepan over medium heat.",
    "Add the chopped onion and cook until softened, about 5 minutes.",
    "Add the chopped carrots, zucchini, and bell pepper, and cook until the vegetables are tender, about 10 minutes.",
    "Add the basmati rice and cook for 1-2 minutes, stirring constantly.",
    "Add the vegetable broth, salt, and black pepper, and bring to a boil.",
    "Reduce the heat to low, cover, and simmer for 15-20 minutes, or until the liquid is absorbed and the rice is tender.",
    "Fluff the pilaf with a fork and stir in the chopped fresh parsley.",
    "Serve hot and enjoy."
  ],
