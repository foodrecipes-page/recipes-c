{
  "title": "Crispy Turkish Kidney Bowl",
  "description": "Savory lamb kidney wrapped in crisp double‑rise bread, served in a lacquerware bowl for a quick weeknight dinner.",
  "cuisine": "Turkish",
  "diet": null,
  "meal": "dinner",
  "ingredients": [
    {
      "name": "lamb kidney",
      "amount": "400 g",
      "notes": "trimmed and sliced into 10 pieces"
    },
    {
      "name": "double‑rise bread",
      "amount": "2 loaves",
      "notes": "pre‑made or homemade"
    },
    {
      "name": "olive oil",
      "amount": "2 tbsp"
    },
    {
      "name": "cherry tomatoes",
      "amount": "200 g",
      "notes": "diced"
    },
    {
      "name": "cucumber",
      "amount": "1",
      "notes": "medium, diced"
    },
    {
      "name": "red onion",
      "amount": "1",
      "notes": "small, diced"
    },
    {
      "name": "fresh parsley",
      "amount": "1/4 cup",
      "notes": "chopped"
    },
    {
      "name": "lemon juice",
      "amount": "1 tbsp"
    },
    {
      "name": "salt",
      "amount": "1 tsp"
    },
    {
      "name": "pepper",
      "amount": "1/2 tsp"
    }
  ],
  "instructions": [
    "Heat olive oil in a skillet over medium heat.",
    "Add the sliced kidneys and sear each side for 2 minutes until browned.",
    "Remove kidneys and set aside.",
    "In the same skillet, toss in cherry tomatoes, cucumber, onion, and parsley for 3 minutes until just softened.",
    "Return the seared kidneys to the skillet and drizzle with lemon juice, salt, and pepper; cook for an additional 1 minute.",
    "Quickly flip the double‑rise bread pieces, place a portion of the kidney mixture on each, and roll tightly.",
    "Arrange the rolls in a lacquerware bowl and serve immediately while still hot."
