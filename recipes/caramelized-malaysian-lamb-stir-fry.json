    },
    {
      "name": "onion",
      "amount": "1 medium"
    },
    {
      "name": "garlic cloves",
      "amount": "3"
    },
    {
      "name": "ginger",
      "amount": "1 tbsp, peeled and julienned"
    },
    {
      "name": "coriander leaves",
      "amount": "20g, for garnish"
    },
    {
      "name": "soy sauce",
      "amount": "2 tbsp"
    },
    {
      "name": "lime juice",
      "amount": "1 tbsp"
    }
  ],
  "instructions": [
    "Heat oil in a wok over medium-high heat.",
    "Add onion and garlic; sauté until translucent, about 3 minutes.",
    "Stir in lamb mince and cook until browned, breaking it up into small pieces with a spoon, about 5 minutes.",
    "Toss in julienned ginger and continue cooking for an additional 2 minutes.",
    "Drizzle soy sauce evenly over the mixture and stir to coat.",
    "Add lime juice and mix well.",
    "Stir in chopped coriander leaves just before serving.",
    "Serve immediately while still hot."
  ],
