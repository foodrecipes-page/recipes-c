{
  "title": "Crumbly German Pistachio Crumble",
  "description": "A nutty and crumbly German dessert featuring pistachios that’s perfect for lazy Sundays and is high-protein-friendly.",
  "cuisine": "German",
  "diet": [
    "high-protein-friendly"
  ],
  "meal": "dessert",
  "ingredients": [
    {
      "name": "almond flour",
      "amount": "1 cup"
    },
    {
      "name": "pistachios",
      "amount": "3/4 cup coarsely chopped"
    },
    {
      "name": "ground almonds",
      "amount": "2 tbsp"
    },
    {
      "name": "baking powder",
      "amount": "1 tsp"
    },
    {
      "name": "salt",
      "amount": "1/8 tsp"
    },
    {
      "name": "brown sugar",
      "amount": "3 tbsp"
    },
    {
      "name": "eggs",
      "amount": "2 large, beaten"
    },
    {
      "name": "vanilla extract",
      "amount": "1 tsp"
    }
  ],
  "instructions": [
    "Preheat oven to 180°C (350°F). Grease a 9x9 inch baking dish.",
    "Mix almond flour, ground almonds, baking powder, and salt in a bowl until well combined. Stir in brown sugar, beaten eggs, and vanilla extract until smooth.",
    "Fold in chopped pistachios gently to avoid breaking them up too much.",
    "Pour the mixture into prepared baking dish and spread evenly.",
    "Bake for 25-30 minutes or until firm on top and golden brown. Allow to cool before serving."
  ],
