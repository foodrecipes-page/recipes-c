{
  "title": "Citrusy Crispy Korean Pretzel Stir-fry",
  "description": "A dairy-free-friendly hangover-cure dish featuring crispy pretzels with a citrusy kick and savory flavors.",
  "cuisine": "Korean",
  "diet": [
