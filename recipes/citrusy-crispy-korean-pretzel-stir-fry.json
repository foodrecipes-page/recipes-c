      "name": "Pretzel sticks",
      "amount": "20 pieces"
    },
    {
      "name": "Orange segments",
      "amount": "1 cup, peeled and sliced"
    },
    {
      "name": "Lemon slices",
      "amount": "1/2 cup"
    },
    {
      "name": "Garlic cloves",
      "amount": "3 cloves"
    },
    {
      "name": "Green onions",
      "amount": "1 stalk, chopped"
    },
    {
      "name": "Red pepper flakes",
      "amount": "1/4 tsp"
    },
    {
      "name": "Coconut oil",
      "amount": "2 tbsp"
    }
  ],
  "instructions": [
    "Heat coconut oil in a non-stick pan over medium heat.",
    "Add orange and lemon slices, garlic, and red pepper flakes. Stir for about 1 minute until fragrant.",
    "Gently add pretzel sticks to the pan; do not overcrowd.",
    "Stir occasionally and cook until golden brown spots form on all sides (about 2 minutes per side).",
    "Remove from heat and toss with chopped green onions."
