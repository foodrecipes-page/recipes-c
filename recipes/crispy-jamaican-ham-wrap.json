      "amount": "1",
      "notes": "whole wheat, low-carb"
    },
    {
      "name": "sprouts",
      "amount": "1/4 cup"
    },
    {
      "name": "peppers",
      "amount": "1/2 cup"
    },
    {
      "name": "onions",
      "amount": "1/2 cup"
    },
    {
      "name": "cucumber",
      "amount": "1/2 cup"
    },
    {
      "name": "ginger",
      "amount": "2 tablespoons"
    },
    {
