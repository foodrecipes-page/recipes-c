      "amount": "1 teaspoon"
    },
    {
      "name": "paprika",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "salsa",
      "amount": "2 tablespoons"
    },
    {
      "name": "cucumber raita",
      "amount": "1/4 cup"
    }
  ],
  "instructions": [
    "Preheat a large non-stick skillet over medium-high heat.",
    "Add the serrano ham slices and cook for 2 minutes on each side.",
    "In a medium bowl, combine the sprouts, peppers, onions, and cucumber.",
    "Add the cooked ham to the bowl and stir to combine.",
    "In a separate bowl, mix the ginger, orange juice, cumin, and paprika.",
    "Add the ginger mixture to the bowl with the ham mixture and stir to combine.",
    "Warm the tortilla in the skillet for 30 seconds on each side.",
    "Assemble the wrap by spreading the ham mixture on one half of the tortilla and folding the other half over.",
    "Serve with salsa and cucumber raita on the side.",
    "Cut in half and serve immediately.",
    "Garnish with cilantro, if desired."
  ],
