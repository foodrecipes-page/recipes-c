{
  "title": "Crispy Jamaican Ham Wrap",
  "description": "A refreshing and savory post-workout snack featuring Jamaican serrano ham and a crispy fold.",
  "cuisine": "jamaican",
  "diet": null,
  "meal": "snack",
  "ingredients": [
