  "ingredients": [
    {
      "name": "boneless chicken breast",
      "amount": "1 pound",
      "notes": "cut into bite-sized pieces"
    },
    {
      "name": "parma ham",
      "amount": "6 slices",
      "notes": "diced"
    },
    {
      "name": "fish sauce",
      "amount": "2 tablespoons"
    },
    {
      "name": "lime juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "coconut milk",
      "amount": "1 cup",
      "notes": "low-fat"
    },
    {
      "name": "brown sugar",
      "amount": "1 tablespoon"
    },
    {
      "name": "Thai red curry paste",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "fresh cilantro",
      "amount": "1/4 cup",
      "notes": "chopped"
    }
  ],
  "instructions": [
    "Heat a large cast-iron skillet over medium-high heat.",
    "Add the diced parma ham and cook until crispy, about 2-3 minutes.",
    "Remove the parma ham from the skillet and set aside.",
    "Add the chicken to the skillet and cook until browned, about 5-6 minutes.",
    "Add the fish sauce, lime juice, coconut milk, brown sugar, curry paste, salt, and pepper to the skillet and stir to combine.",
    "Return the parma ham to the skillet and stir to combine.",
    "Reduce heat to medium-low and simmer, uncovered, until the sauce has thickened and the chicken is cooked through, about 10-12 minutes.",
    "Stir in the chopped cilantro and serve hot."
  ],
