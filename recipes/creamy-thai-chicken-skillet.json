{
  "title": "Creamy Thai Chicken Skillet",
  "description": "A kid-friendly Thai dish featuring parma ham and a sour yet pillowy texture, made in a cast-iron skillet with a low-calorie twist.",
  "cuisine": "Thai",
  "diet": [
    "low-calorie",
    "gluten-free"
  ],
