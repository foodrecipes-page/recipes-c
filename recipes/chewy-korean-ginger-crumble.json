{
  "title": "Chewy Korean Ginger Crumble",
  "description": "This raw-friendly meal-prep dish features chewy ginger crumbles made with buttermilk and air-fried for a Korean twist, perfect for breakfast or snack.",
  "cuisine": "Korean",
  "diet": null,
  "meal": "snack",
  "ingredients": [
    {
      "name": "2 cups grated raw ginger",
      "amount": "",
      "notes": "Use fresh or frozen ginger"
    },
    {
      "name": "1 cup buttermilk",
      "amount": "",
      "notes": "At least 3.25% milkfat"
    },
    {
      "name": "1/4 cup rice flour (optional for texture)",
      "amount": "",
      "notes": "To make crumbles less sticky"
    },
    {
      "name": "Pinch of salt",
      "amount": "",
      "notes": ""
    }
  ],
  "instructions": [
    "Combine grated ginger and buttermilk in a mixing bowl.",
    "Stir in rice flour (if using) to help crumble form better.",
    "Season with a pinch of salt, if desired.",
    "Transfer the mixture to an air fryer basket lined with parchment paper.",
    "Air-fry at 300°F for about 12-15 minutes or until lightly golden and crisp.",
    "Remove from air fryer and allow to cool completely before portioning out."
  ],
