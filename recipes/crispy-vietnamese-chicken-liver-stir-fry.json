      "name": "chicken liver",
      "amount": "1 pound",
      "notes": "sliced into thin strips"
    },
    {
      "name": "vegetable oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "thinly sliced"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "ginger",
      "amount": "1 tablespoon",
      "notes": "grated"
    },
    {
      "name": "ferment-kimchi",
      "amount": "1 cup",
      "notes": "chopped"
    },
    {
      "name": "fish sauce",
      "amount": "2 tablespoons"
    },
    {
      "name": "lime juice",
      "amount": "1 tablespoon"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Heat the vegetable oil in a wok over medium-high heat.",
    "Add the sliced onion and cook until it is translucent and starting to caramelize.",
    "Add the minced garlic and grated ginger and cook for 1 minute.",
    "Add the sliced chicken liver and cook until it is browned and crispy.",
    "Add the chopped ferment-kimchi, fish sauce, lime juice, salt, and black pepper, and stir-fry for 2 minutes.",
    "Taste and adjust the seasoning as needed.",
    "Transfer the stir-fry to a serving platter and serve immediately.",
    "Garnish with additional chopped ferment-kimchi and lime wedges if desired."
  ],
