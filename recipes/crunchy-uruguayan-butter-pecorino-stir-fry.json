      "amount": "1 cup grated"
    },
    {
      "name": "Butter",
      "amount": "2 tablespoons"
    },
    {
      "name": "Garlic",
      "amount": "3 cloves, minced"
    },
    {
      "name": "Red Onion",
      "amount": "1 medium, finely chopped"
    },
    {
      "name": "Green Peppers",
      "amount": "2, sliced"
    },
    {
      "name": "Olive Oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "Salt",
      "amount": "to taste"
    },
    {
      "name": "Black Pepper",
      "amount": "to taste"
    }
  ],
  "instructions": [
    "Heat the olive oil in a wok or large skillet over medium heat.",
    "Add minced garlic and sauté for about 1 minute until fragrant.",
    "Gradually add chopped red onion and green peppers, cooking for about 5 minutes until softened.",
    "Stir in grated pecorino cheese along with the butter. Cook for another 2-3 minutes or until the cheese is melted and mixture starts to bubble and turn golden brown.",
    "Season with salt and pepper to taste.",
    "Serve hot as a snack or appetizer."
  ],
