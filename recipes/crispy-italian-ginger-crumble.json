      "name": "2 cups grated zucchini"
    },
    {
      "name": "1/4 cup almond flour"
    },
    {
      "name": "Juice of 3 lemons"
    },
    {
      "name": "Juice of 1 orange"
    },
    {
      "name": "1 tablespoon honey"
    },
    {
      "name": "2 tablespoons olive oil"
    },
    {
      "name": "2 tablespoons grated lemon zest"
    },
    {
      "name": "1/4 teaspoon ground ginger"
    },
    {
      "name": "Pinch of salt"
    }
  ],
  "instructions": [
    "Preheat oven to 375°F (190°C).",
    "In a large bowl, mix the zucchini, almond flour, lemon juice, orange juice, honey, olive oil, lemon zest, ground ginger, and salt.",
