{
  "title": "Crispy Filipino Apple Crumble with Apple Cider Vinegar",
  "description": "A sour and crispy post-workout dish featuring apple cider vinegar as a key ingredient, perfect for those who prefer dairy-free options.",
  "cuisine": "Filipino",
  "diet": [
    "dairy-free"
  ],
  "meal": "snack",
  "ingredients": [
    {
      "name": "1 cup mixed diced apples",
      "amount": "cup"
    },
    {
      "name": "2 tablespoons apple cider vinegar",
      "amount": "tbsp"
    },
    {
      "name": "1/4 cup all-purpose flour",
      "amount": "cup"
    },
    {
      "name": "1/2 teaspoon ground cinnamon",
      "amount": "teaspoon"
    },
    {
      "name": "Pinch of salt",
      "amount": "pinch"
    },
    {
      "name": "1/3 cup unsweetened almond milk",
      "amount": "cup"
    },
    {
      "name": "Grated zest and juice from 1 lime",
      "notes": "use for sourness"
    },
    {
      "name": "4 tablespoons coconut oil, melted",
      "amount": "tablespoons"
    }
  ],
  "instructions": [
    "Preheat oven to 350\u00b0F (175\u00b0C).",
    "Combine apples, apple cider vinegar, flour, cinnamon, and salt in a large bowl.",
    "Slowly pour in almond milk while stirring until the mixture reaches a smooth consistency.",
    "Fold in grated lime zest and juice gently.",
    "Pour the mixture into an 8-inch square baking dish.",
    "Melt coconut oil, then spread evenly over top of the batter.",
    "Bake for about 25-30 minutes or until golden brown on top and crispy around the edges.",
    "Let cool before serving."
  ],
