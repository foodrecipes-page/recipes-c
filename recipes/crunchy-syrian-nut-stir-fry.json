  "ingredients": [
    {
      "name": "Scotch Bonnet Peppers",
      "amount": "4-6 pieces",
      "notes": "For spiciness"
    },
    {
      "name": "Bhuna Paste",
      "amount": "1 tablespoon",
      "notes": "Or use a mix of ground spices like cumin, coriander, and turmeric for nut-free option"
    },
    {
      "name": "Onion",
      "amount": "1 medium",
      "notes": ""
    },
    {
      "name": "Garlic Cloves",
      "amount": "3-4 pieces",
      "notes": ""
    },
    {
      "name": "Tomatoes",
      "amount": "2 ripe",
      "notes": "For natural sweetness and acidity"
    },
    {
      "name": "Red Bell Pepper",
      "amount": "1 medium",
      "notes": "To add color and crunch"
    },
    {
      "name": "Cayenne Pepper",
      "amount": "Pinch",
      "notes": ""
    },
    {
      "name": "Salt",
      "amount": "To taste",
      "notes": ""
    },
    {
      "name": "Oil",
      "amount": "2 tablespoons",
      "notes": "For stir-frying"
    }
  ],
  "instructions": [
    "Heat oil in a pan over medium-high heat.",
    "Add scotch bonnet peppers and bhuna paste, sauté until fragrant and slightly softened.",
    "Chop onion into small pieces and add to the pan. Sauté for about 2 minutes or until translucent.",
    "Add garlic cloves and cook for another minute.",
    "Slice tomatoes and red bell pepper. Add them to the pan along with cayenne pepper and salt, stir-fry for a few more minutes.",
    "Adjust seasoning as needed.",
    "Serve hot as a snack or side dish."
  ],
