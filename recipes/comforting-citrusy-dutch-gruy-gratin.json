  "instructions": [
    "preheat oven to 180\u000040c",
    "slice the onion and saut\u00029 in a pan until caramelized",
    "add the minced garlic and cook for 1 minute",
    "in a separate pot, steam the chicken breast until cooked through",
    "in a large mixing bowl, combine the grated gruy cheese, lemon juice, lime juice, eggs, salt, black pepper, and parsley",
    "add the cooked chicken breast to the cheese mixture and stir until combined",
    "transfer the mixture to a bamboo steamer and top with the caramelized onion and bonito flakes",
    "bake in the oven for 20 minutes or until the top is golden brown and the cheese is melted and bubbly",
    "remove from the oven and sprinkle with fleur de sel",
    "serve hot and enjoy"
  ],
