      "name": "onion",
      "amount": "1 medium, sliced"
    },
    {
      "name": "garlic",
      "amount": "3 cloves, minced"
    },
    {
      "name": "tomato puree",
      "amount": "200 g"
    },
    {
      "name": "cumin seeds",
      "amount": "1 tsp"
    },
    {
      "name": "coriander powder",
      "amount": "1 tsp"
    },
    {
      "name": "turmeric",
      "amount": "1/2 tsp"
    },
    {
      "name": "garam masala",
      "amount": "1 tsp"
    },
    {
      "name": "low-fat yogurt",
      "amount": "100 g"
    },
    {
      "name": "fresh cilantro",
      "amount": "10 g, chopped"
    },
    {
      "name": "salt",
      "amount": "1 tsp"
    },
    {
      "name": "olive oil",
      "amount": "1 tbsp"
    }
  ],
  "instructions": [
    "Preheat the lazy-susan-spinner to 200°C.",
    "Cut the tofu into 1-cm cubes and slice the onion.",
    "Place the tofu and onion on the spinner tray, drizzle with olive oil, and char until browned.",
    "Transfer the charred tofu and onion to a saucepan and add cumin seeds, letting them pop.",
    "Add minced garlic and sauté until fragrant.",
    "Stir in tomato puree, coriander powder, turmeric, garam masala, and salt, then simmer for 5 minutes.",
    "Fold in the charred tofu and onion, cook for an additional 3 minutes.",
    "Remove from heat, whisk in low-fat yogurt until the mixture is creamy and aerated.",
    "Garnish with chopped cilantro and serve hot."
  ],
