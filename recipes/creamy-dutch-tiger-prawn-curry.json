      "notes": "peeled and deveined"
    },
    {
      "name": "coconut milk",
      "amount": "1 can"
    },
    {
      "name": "curry powder",
      "amount": "2 tablespoons"
    },
    {
      "name": "coriander seeds",
      "amount": "1 tablespoon"
    },
    {
      "name": "cumin seeds",
      "amount": "1 tablespoon"
    },
    {
      "name": "vegetable oil",
      "amount": "2 tablespoons"
    },
    {
      "name": "onion",
      "amount": "1 medium",
      "notes": "chopped"
    },
    {
      "name": "garlic",
      "amount": "3 cloves",
      "notes": "minced"
    },
    {
      "name": "salt",
      "amount": "1 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/2 teaspoon"
    }
  ],
  "instructions": [
    "Heat the oil in a large pan over medium heat.",
    "Add the onion and cook until it is translucent.",
    "Add the garlic, coriander seeds, and cumin seeds, and cook for 1 minute.",
    "Using a mortar and pestle, pound the curry powder into a fine paste.",
    "Add the curry paste to the pan and cook for 1 minute.",
    "Add the tiger prawns and cook until they are pink and fully cooked.",
    "Add the coconut milk and stir to combine.",
    "Bring the mixture to a simmer and cook until it has thickened slightly.",
    "Season with salt and black pepper to taste.",
    "Serve the curry hot over rice or with naan bread."
  ],
