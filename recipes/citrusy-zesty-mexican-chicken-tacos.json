  "instructions": [
    "heat grill to medium-high heat",
    "season chicken breast with cumin, coriander, chili powder, and salt",
    "grill chicken for 5 minutes per side, or until cooked through",
    "set aside and rest for 5 minutes",
    "heat 1 tbsp oil in a large skillet over medium-high heat",
    "add mirepoix and cook until softened, about 5 minutes",
    "add sake and cook for 2 minutes, or until reduced by half",
    "add citrus juice and cook for 1 minute",
    "add chicken to the skillet and toss to coat with sauce",
    "serve with cilantro and your choice of toppings"
