{
  "title": "Creamy Nostalgic Brazilian Tomatoes Stir-fry",
  "description": "A fresh and creamy dish featuring canned tomatoes that transports you back in time with its simple yet comforting flavors.",
  "cuisine": "Brazilian",
  "diet": null,
  "meal": "dinner",
  "ingredients": [
    {
      "name": "2 cups",
      "amount": "fresh cherry tomatoes",
      "notes": "Washed and halved"
    },
    {
      "name": "1 can (400g)",
      "amount": "canned diced tomatoes",
      "notes": "Drained"
    },
    {
      "name": "3 cloves",
      "amount": "garlic",
      "notes": "Chopped finely"
    },
    {
      "name": "2 tablespoons",
      "amount": "olive oil"
    },
    {
      "name": "1/4 cup",
      "amount": "heavy cream"
    },
    {
      "name": "Salt and pepper",
      "amount": "to taste"
    },
    {
      "name": "Fresh basil leaves",
      "amount": "for garnish"
    }
  ],
  "instructions": [
    "Heat the olive oil in a skillet over medium heat.",
    "Add halved cherry tomatoes, diced garlic, and cook for about 5 minutes or until the tomatoes start to soften.",
    "Stir in the canned tomatoes, reduce heat to low, cover, and simmer for another 10 minutes.",
    "Whisk in heavy cream, salt, and pepper. Let it come to a gentle boil before removing from heat.",
    "Serve hot with fresh basil leaves on top."
  ],
