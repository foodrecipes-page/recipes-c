{
  "title": "Cardamom Bliss Custard Tart",
  "description": "A creamy, savory American dish featuring roasted green cardamom pods in a dairy-free custard filling served as a light dessert.",
  "cuisine": "American",
  "diet": [
    "dairy-free"
  ],
  "meal": "dessert",
