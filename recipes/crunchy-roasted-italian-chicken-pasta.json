    {
      "name": "boneless chicken breast",
      "amount": "1 pound",
      "notes": "cut into bite-sized pieces"
    },
    {
      "name": "pasta",
      "amount": "8 ounces",
      "notes": "penne or fusilli work well"
    },
    {
      "name": "Marmite",
      "amount": "2 tablespoons"
    },
    {
      "name": "olive oil",
      "amount": "1/4 cup"
    },
    {
      "name": "garlic powder",
      "amount": "1 teaspoon"
    },
    {
      "name": "salt",
      "amount": "1/2 teaspoon"
    },
    {
      "name": "black pepper",
      "amount": "1/4 teaspoon"
    },
    {
      "name": "grated Parmesan cheese",
      "amount": "1/2 cup"
    }
  ],
  "instructions": [
    "Preheat the air fryer to 400 degrees Fahrenheit.",
    "Toss the chicken with olive oil, garlic powder, salt, and black pepper, and cook in the air fryer for 10 minutes.",
    "Cook the pasta according to package instructions until al dente.",
    "In a large bowl, combine cooked pasta, roasted chicken, and Marmite, and toss to combine.",
    "Sprinkle grated Parmesan cheese on top and serve hot.",
    "Garnish with chopped fresh parsley or basil, if desired.",
    "Serve immediately and enjoy.",
    "Refrigerate or freeze leftovers for up to 3 days."
  ],
