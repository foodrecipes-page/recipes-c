      "amount": "10 eggs"
    },
    {
      "name": "Pinenuts (or walnuts)",
      "amount": "2 tablespoons"
    },
    {
      "name": "Sour cherry preserves",
      "amount": "1 tablespoon"
    },
    {
      "name": "Water chestnut slices",
      "amount": "5-6 pieces"
    },
    {
      "name": "Red pepper flakes",
      "amount": "A pinch"
    }
  ],
  "instructions": [
    "Beat the egg whites until frothy, then fold in sour cherry preserves and red pepper flakes.",
    "Heat a pan over medium heat. Add pinenuts to toast lightly.",
    "Add water chestnut slices to the pan with toasted pinenuts, cook for about 1 minute.",
    "Pour beaten eggs onto the pan, spreading evenly while still hot.",
    "Serve immediately."
