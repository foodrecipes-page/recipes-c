{
  "title": "Chewy Kenyan Garlic Roll",
  "description": "A crowd-pleasing garlic-infused pastry roll that's low in calories and easy to prepare.",
  "cuisine": "Kenyan",
  "diet": [
    "low-calorie-friendly"
  ],
  "meal": "snack",
  "ingredients": [
    {
      "name": "ready rolled shortcrust pastry",
      "amount": "1 sheet"
    },
    {
      "name": "minced garlic",
      "amount": "2 cloves"
    },
    {
      "name": "olive oil",
      "amount": "1 tbsp"
    },
    {
      "name": "low-sodium soy sauce",
      "amount": "1/4 cup"
    },
    {
      "name": "turmeric powder",
      "amount": "1/8 tsp"
    },
    {
      "name": "ginger paste",
      "amount": "2 tsp"
    },
    {
      "name": "chopped fresh cilantro (coriander)",
      "amount": "1 tbsp"
    }
  ],
  "instructions": [
    "Preheat oven to 350°F (175°C).",
    "Place the sheet of ready rolled shortcrust pastry on a baking sheet.",
    "Blend minced garlic, olive oil, low-sodium soy sauce, turmeric powder, and ginger paste in a small bowl. Mix well until smooth.",
    "Spread the blended mixture evenly over the top of the pastry sheet.",
    "Sprinkle chopped fresh cilantro (coriander) on top of the seasoned dough.",
    "Bake for 15 minutes or until golden brown.",
    "Remove from oven and let it cool slightly before serving."
  ],
