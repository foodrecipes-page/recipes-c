{
  "slug": "citrusy-gooey-irish-turnips-stew",
  "title": "Irish Citrus Stew",
  "description": "A hearty and flavorful stew perfect for a chilly evening, made with tender turnips and a hint of citrus.",
  "cuisine": "irish",
  "diet": [
