  "instructions": [
    "Heat butter in a large pan over medium heat.",
    "Add chopped onion and cook until softened, about 3-4 minutes.",
    "Add grated ginger and minced garlic and cook for another minute.",
    "Add curry powder and garam masala and cook for 1 minute, until fragrant.",
    "Add heavy cream and bring to a simmer.",
    "Reduce heat to low and let sauce simmer for 5 minutes.",
    "Add cheese and stir until melted and smooth.",
    "Season with salt to taste.",
    "Serve hot, garnished with chopped cilantro."
