      "name": "Tofu",
      "amount": "1 block (14 oz)",
      "notes": "pressed and drained"
    },
    {
      "name": "Crispy",
      "amount": "2 cups",
      "notes": "panko breadcrumbs"
    },
    {
      "name": "Smoky",
      "amount": "2 tbsp",
      "notes": "smoked paprika"
    },
    {
      "name": "Croatian",
      "amount": "2 tbsp",
      "notes": "olive oil"
    },
    {
      "name": "Skewers",
      "amount": "10-12 bamboo skewers",
      "notes": "soaked in water for 30 minutes"
    },
    {
      "name": "Salt",
      "amount": "1 tsp",
      "notes": "to taste"
    },
    {
      "name": "Pepper",
      "amount": "1 tsp",
      "notes": "to taste"
    }
  ],
  "instructions": [
    "1. Preheat grill to medium-high heat.",
    "2. Cut the tofu into 1-inch cubes and place on a plate.",
    "3. In a shallow dish, mix together crispy, smoky, and a pinch of salt and pepper.",
    "4. Dip each tofu cube into the mixture, coating evenly.",
    "5. Thread 3-4 tofu cubes onto each skewer.",
    "6. Brush the skewers with Croatian.",
    "7. Grill the skewers for 3-4 minutes per side, or until crispy and smoky.",
    "8. Serve hot and garnish with additional crispy, if desired."
  ],
